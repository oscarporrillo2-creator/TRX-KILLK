        print("WHATSAPP: [Verificación técnica pendiente]")
        print("INSTAGRAM: [Verificación técnica pendiente]")
        print("\nBUSCANDO MÁS INFORMACIÓN..........")
        print("[!] Sin resultados adicionales en bases de datos abiertas.")
    except: print("[-] Error al procesar número.")

# --- OPCIÓN 2: SCANNER NÚMERO ---
def scanner_numero():
    os.system('clear')
    num = input("[+] Scanner activo. Ingresa número: ")
    p = phonenumbers.parse(num, None)
    print(f"\n[✓] Escaneando prefijo: {p.country_code}")
    print(f"[✓] Operadora detectada: {carrier.name_for_number(p, 'es')}")
    print(f"[✓] Zona Horaria: {timezone.time_zones_for_number(p)}")

# --- OPCIÓN 7: GUARDAR ---
