    print(" OPCIONES\033[0m")

def main():
    # Inicia el servidor en segundo plano
    threading.Thread(target=start_server, daemon=True).start()
    
    while True:
        banner()
        print(" [1] NÚMERO INFORMACIÓN  | [2] LINK-ZP         | [3] CREADOR")
