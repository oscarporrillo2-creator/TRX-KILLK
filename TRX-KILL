def escaneo_osint_local():
    entrada = input("\033[1;32m[?]\033[0m Ingrese el número de teléfono objetivo: ").strip()
    num_limpio = re.sub(r'[^\d]', '', entrada)

    if len(num_limpio) < 10:
        codigo = menu_codigos_pais()
        if codigo: 
            num_limpio = codigo + num_limpio
        else: 
            num_limpio = input("\033[1;32m[?]\033[0m Prefijo manual (ej: 54): ").strip() + num_limpio

    print(f"\033[1;34m\n[*] PROCESANDO IDENTIFICADOR: +{num_limpio}...\033[0m")
    sleep(1)

    # 1. Identificar País por prefijo
    pais_final = "Desconocido"
    todos_los_prefijos = []
    for cont, paises in PREFIJOS_PAISES.items():
        for p, c in paises.items():
            todos_los_prefijos.append((p, c))
    todos_los_prefijos.sort(key=lambda x: len(x[1]), reverse=True)
    
    for p, c in todos_los_prefijos:
        if num_limpio.startswith(c):
            pais_final = p
            break

    # 2. Obtener Coordenadas Generales del País (Ubicación Geográfica de Red)
    lat, lon, link_maps = "N/A", "N/A", "N/A"
    if pais_final != "Desconocido":
        try:
            query_encoded = urllib.parse.quote(pais_final)
            url_api = f"https://nominatim.openstreetmap.org/search.php?q={query_encoded}&format=json"
            req_geo = urllib.request.Request(url_api, headers={'User-Agent': 'TRX-LILL/3.0'})
            with urllib.request.urlopen(req_geo) as resp:
                datos_geo = json.loads(resp.read().decode())
                if datos_geo:
                    lat = datos_geo[0]["lat"]
                    lon = datos_geo[0]["lon"]
                    link_maps = f"https://www.google.com/maps?q={lat},{lon}"
        except Exception:
            link_maps = "Error al generar mapa base"

    # 3. Generación de Enlaces de Búsqueda de Redes (Pivots OSINT)
    link_wa = f"https://wa.me/{num_limpio}"
    link_tg = f"tg://resolve?phone={num_limpio}"

    # Mostrar Resultados en la Consola Local
    print("\n\033[1;31m=====================================================\033[0m")
    print(f"\033[1;32m MOVIL:\033[0m +{num_limpio}")
    print(f"\033[1;32m PAÍS:\033[0m {pais_final}")
    print(f"\033[1;32m IP PAÍS EXACTA:\033[0m Módulo de IP Remota no disponible por diseño")
    print(f"\033[1;32m LINK (GOOGLE MAP):\033[0m \033[1;36m{link_maps}\033[0m")
    print(f"\033[1;32m REDES SOCIALES CON ESE NÚMERO:\033[0m")
    print(f"   -> [WhatsApp Pivot]: \033[1;34m{link_wa}\033[0m")
    print(f"   -> [Telegram Pivot]: \033[1;34m{link_tg}\033[0m")
    print("\033[1;31m=====================================================\033[0m\n")
    
    input("Presiona Enter para volver al menú...")

