                with open(report, "a", encoding="utf-8") as f:
                    f.write("=== TRX-KILL REPORT ===\n")
                    f.write("INTERNATIONAL NUMBER: " + international + "\n")
                    f.write("LOCAL NUMBER: " + localNumber + "\n")
                    f.write("COUNTRY PREFIX: " + numberCode + "\n")
                    f.write("COUNTRY CODE: " + numberNation + "\n")
                    f.write("COUNTRY: " + str(nation) + "\n")
                    f.write("CARRIER/ISP: " + str(carrierName) + "\n")
                    f.write("=======================\n")
            except Exception:
                pass

            # Formateo de payloads para el ecosistema de herramientas
            formatted2 = str(international).replace(numberCode, "").replace(" ", "-")
            formatted3 = formatted2.replace("-", "", 1)
            formatted4 = str(international).replace(numberCode, "0").replace(" ", "")
            formatted1 = "({}{}){}".format("%2B", numberCode, str(formatted2).replace("-", "", 1))
            formatted5 = formatted4.replace("0", "", 1)
            
            phoneList.extend([formatted1, formatted2, formatted4, formatted5])
            
