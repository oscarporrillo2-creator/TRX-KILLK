def obtener_coordenadas_pais(codigo_region):
    coordenadas = {
        "AR": "-34.6037,-58.3816", "MX": "19.4326,-99.1332", "CO": "4.7110,-74.0721",
        "ES": "40.4167,-3.7037",  "PE": "-12.0464,-77.0428", "CL": "-33.4489,-70.6693",
        "VE": "10.4806,-66.9036", "EC": "-0.1807,-78.4678", "BR": "-15.7938,-47.8828",
        "US": "37.0902,-95.7129", "UY": "-34.9011,-56.1645", "BO": "-16.2902,-63.5887"
    }
    return coordenadas.get(codigo_region.upper(), "0.0000,0.0000")


def buscar_rastros_web(numero_telefono):
    print(f"\n\033[1;34m[*] Escaneando indexaciones públicas para: {numero_telefono}...\033[0m")
    query = f'"{numero_telefono}"'
    query_codificada = urllib.parse.quote_plus(query)
    url_completa = f"https://www.google.com/search?q={query_codificada}"
    
    headers = {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
    }
    try:
        respuesta = requests.get(url_completa, headers=headers, timeout=10)
        if respuesta.status_code == 200:
            print("\033[1;32m[✓] Análisis de huella digital finalizado.\033[0m")
            return url_completa
        else:
            return "Servicio de auditoría manual requerido"
    except Exception:
        return "Error en conexión asíncrona"


