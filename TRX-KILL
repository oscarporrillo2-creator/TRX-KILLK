import os
import sys
import phonenumbers
from phonenumbers import carrier, geocoder, timezone
from time import sleep

# Configuración de limpieza de pantalla
class Clear:
    class Screen:
        @staticmethod
        def Clear(): os.system('clear' if os.name == 'posix' else 'cls')

def mostrar_banner_trx():
    print("\033[1;31m" + r"""
  _________ ______  __   __       _      _____ _      _      
 |__   __|  ____\ \ \ / /      | |    |_   _| |    | |     
    | |  | |__   \ \ ' /       | |      | | | |    | |     
    | |  |  __|   > > <        | |      | | | |    | |     
    | |  | |____ / / . \       | |____ _| |_| |____| |____ 
    |_|  |_|____/_/_/ \_\      |______|_____|______|______|
    """ + "\033[0m")
    print("\033[1;33m" + "        [+] REAL OSINT & TELECOM LOOKUP ENGINE [+]" + "\033[0m")
    print("\033[1;30m" + "   =====================================================" + "\033[0m\n")

# --- OPCIÓN 1: CONSULTA EXTENDIDA ---
def consulta_extendida():
    Clear.Screen.Clear()
    mostrar_banner_trx()
    num = input("\033[1;32m[+] Ingresa el número (ej: 54911xxxxxxxx): \033[0m")
    try:
        p = phonenumbers.parse("+" + num, None)
        print("\n\033[1;33m[!] VERIFICANDO NÚMERO...\033[0m")
        sleep(1.5)
        print(f"\n\033[1;36mMÓVIL:\033[0m +{num}")
        print(f"\033[1;36mPAÍS:\033[0m {geocoder.country_name_for_number(p, 'es')}")
        print(f"\033[1;36mMAPA:\033[0m Localización nacional")
        print(f"\033[1;36mGOOGLE MAP LINK:\033[0m https://www.google.com/maps/search/{geocoder.country_name_for_number(p, 'es')}")
        print("\n\033[1;31m--- REPORTES ---\033[0m")
        print("WHATSAPP: [NO]")
        print("INSTAGRAM: [NO]")
        print("\n\033[1;30mBUSCANDO MÁS INFORMACIÓN..........\033[0m")
        sleep(1)
        print("[+] Sin registros adicionales encontrados.")
    except: print("\033[1;31m[!] Error al procesar.\033[0m")

# --- OPCIÓN 2: SCANNER NÚMERO ---
def scanner_numero():
    Clear.Screen.Clear()
    mostrar_banner_trx()
    num = input("\033[1;32m[+] Scanner activo. Ingresa número: \033[0m")
    try:
        p = phonenumbers.parse("+" + num, None)
        print(f"\n\033[1;36m[✓] Prefijo:\033[0m {p.country_code}")
        print(f"\033[1;36m[✓] Operadora:\033[0m {carrier.name_for_number(p, 'es')}")
        print(f"\033[1;36m[✓] Zona Horaria:\033[0m {timezone.time_zones_for_number(p)}")
    except: print("\033[1;31m[-] Error en scanner.\033[0m")

# --- OPCIÓN 7: GUARDAR TODO ---
def guardar_reporte():
    carpeta = input("\033[1;32m[+] Ingresa nombre de la carpeta: \033[0m")
    if not os.path.exists(carpeta): os.makedirs(carpeta)
    with open(f"{carpeta}/reporte.txt", "w") as f:
        f.write("Reporte de TRX-KILL OSINT")
    print(f"\033[1;32m[✓] Guardado en ./{carpeta}/\033[0m")

