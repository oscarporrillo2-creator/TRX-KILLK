def localizar_ip_en_mapa():
    Clear.Screen.Clear()
    mostrar_banner_trx()
    print("\033[1;34m[*] RECOLECTOR DE DATOS GEOGRÁFICOS POR IP [*]\033[0m\n")
    ip_objetivo = input("\033[1;32m[+] Ingresa la dirección IP a rastrear: \033[0m")
    
    url = f"http://ip-api.com/json/{ip_objetivo}?fields=status,message,country,regionName,city,zip,lat,lon,isp"
    
    try:
        print("\033[1;30m[*] Conectando con las bases de datos de redes locales...\033[0m")
        sleep(0.5)
        echo = requests.get(url, timeout=10)
        datos = echo.json()
        
        if datos["status"] == "success":
            lat = datos["lat"]
            lon = datos["lon"]
            mapa_url = f"https://www.google.com/maps?q={lat},{lon}"
            
            print("\n\033[1;32m[✓] DATOS DE RED ENCONTRADOS PARA LA IP:\033[0m")
            print(f" \033[1;36mPAÍS:\033[0m {datos['country']}")
            print(f" \033[1;36mPROVINCIA/ESTADO:\033[0m {datos['regionName']}")
            print(f" \033[1;36mLOCALIDAD/CIUDAD:\033[0m {datos['city']}")
            print(f" \033[1;36mCÓDIGO POSTAL:\033[0m {datos['zip'] if datos['zip'] else 'Oculto/Privado'}")
            print(f" \033[1;36mPROVEEDOR INTERNET (ISP):\033[0m {datos['isp']}")
            print(f" \033[1;36mCOORDS APROX BARRIO:\033[0m {lat}, {lon}")
            print(f"\n\033[1;33m[+] LINK PARA ABRIR EN GOOGLE MAPS:\033[0m\n {mapa_url}")
            
            reporte_path = os.path.join(BASE_DIR, "result-trx-kill.txt")
            with open(reporte_path, "a", encoding="utf-8") as f:
                f.write("\n=====================================================\n")
                f.write(f"RASTREO IP: {ip_objetivo}\n")
                f.write(f"UBICACIÓN: {datos['city']}, {datos['regionName']}, {datos['country']}\n")
                f.write(f"PROVEEDOR: {datos['isp']}\n")
                f.write(f"MAPA DE COORDENADAS: {mapa_url}\n")
