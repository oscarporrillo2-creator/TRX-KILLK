@app.route('/log')
def log():
    lat = request.args.get('lat', '0')
    lon = request.args.get('lon', '0')
    # Guardamos latitud y longitud
    with open(LOG_FILE, "a") as f:
        f.write(f"LAT:{lat}|LON:{lon}\n")
    return "OK"

