import json
import urllib.request
import urllib.parse
import phonenumbers
from phonenumbers import geocoder, carrier, timezone
from time import sleep

def mostrar_banner():
    # Banner personalizado con tu nombre TRX-LILL
    print("\033[1;31m" + r"""
  _________ ______  __   __       _      _____ _      _      
 |__   __|  ____\ \ \ / /      | |    |_   _| |    | |     
    | |  | |__   \ \ ' /       | |      | | | |    | |     
    | |  |  __|   > > <        | |      | | | |    | |     
    | |  | |____ / / . \       | |____ _| |_| |____| |____ 
    |_|  |_|____/_/_/ \_\      |______|_____|______|______|
    """ + "\033[0m")
    print("\033[1;33m" + "      [+] ENHANCED OSINT PHONE LOOKUP BY TRX-LILL [+]" + "\033[0m")
    print("\033[1;30m" + "   =====================================================" + "\033[0m\n")

def buscar_numero():
    mostrar_banner()
    num = input("\033[1;32m[?]\033[0m Introduce el número (ej: 54911xxxxxxx o con +): ")
    
    # Asegurar el formato con el símbolo '+'
    if not num.startswith("+"):
        num_formateado = "+" + num
    else:
        num_formateado = num

    print("\033[1;34m\n[*] ESCANEANDO E INFORMANDO NÚMERO...\033[0m")
    sleep(2)

    try:
        # Parsear el número telefónico
        phone_obj = phonenumbers.parse(num_formateado, None)
        
        # Validar existencia real del número
        if not phonenumbers.is_valid_number(phone_obj):
            print("\033[1;31m[-] NÚMERO NO REAL O INVÁLIDO\033[0m")
            if not phonenumbers.is_possible_number(phone_obj):
                print("\033[1;31m[-] El número ingresado es completamente improbable.\033[0m")
                return
        else:
            print("\033[1;34m[I] ESTADO: El número es válido y real.\033[0m")

        # --- EXTRACCIÓN DE INFORMACIÓN AVANZADA ---
        # Códigos y formatos de numeración
        numero_e164 = phonenumbers.format_number(phone_obj, phonenumbers.PhoneNumberFormat.E164).replace("+", "")
        prefijo_pais = phonenumbers.format_number(phone_obj, phonenumbers.PhoneNumberFormat.INTERNATIONAL).split(" ")[0]
        codigo_region = phonenumbers.region_code_for_country_code(int(prefijo_pais.replace("+", "")))
        numero_local = phonenumbers.format_number(phone_obj, phonenumbers.PhoneNumberFormat.E164).replace(prefijo_pais.replace("+", ""), "")
        numero_internacional = phonenumbers.format_number(phone_obj, phonenumbers.PhoneNumberFormat.INTERNATIONAL)

        # Datos de Registro / Compañía / Ubicación básica
        pais = geocoder.country_name_for_number(phone_obj, "en")
        localizacion = geocoder.description_for_number(phone_obj, "en")
        operador = carrier.name_for_number(phone_obj, "en")

        # Imprimir resultados de texto obtenidos
        print(f"\033[1;33m[v]\033[0m NÚMERO INTERNACIONAL: {numero_internacional}")
        print(f"\033[1;33m[v]\033[0m NÚMERO LOCAL: {numero_local}")
        print(f"\033[1;33m[v]\033[0m PREFIJO DE PAÍS: {prefijo_pais}")
        print(f"\033[1;33m[v]\033[0m CÓDIGO DE PAÍS (ISO): {codigo_region}")
        print(f"\033[1;33m[v]\033[0m PAÍS DE ORIGEN: {pais}")
        print(f"\033[1;33m[v]\033[0m ÁREA / PROVINCIA: {localizacion if localizacion else 'No especificada'}")
        print(f"\033[1;33m[v]\033[0m OPERADOR TELEFÓNICO / ISP: {operador if operador else 'Desconocido'}")

        # Indexación de Zonas Horarias
        idx = 1
        for tz in timezone.time_zones_for_number(phone_obj):
            print(f"\033[1;33m[v]\033[0m ZONA HORARIA N°{idx}: {tz}")
            idx += 1
        sleep(1)

        # Formateos alternativos generados automáticamente
        print("\033[1;32m\n[+] FORMATEANDO ESTRUCTURAS DE NÚMERO...\033[0m")
        sleep(1)
        fmt_rfc3966 = f"tel:{numero_internacional.replace(' ', '-')}"
        print(f"\033[1;33m[v]\033[0m FORMATO INTERNACIONAL E164: +{numero_e164}")
        print(f"\033[1;33m[v]\033[0m FORMATO RFC3966: {fmt_rfc3966}")

        # --- SECCIÓN DE GEOLOCALIZACIÓN COMPLETA (OpenStreetMap API) ---
        # Determinar el string exacto para buscar las coordenadas en el mapa
        if localizacion:
            zona_busqueda = localizacion
        else:
            zona_busqueda = pais

        if zona_busqueda:
            print("\033[1;32m\n[+] CONSULTANDO COORDENADAS GEOGRÁFICAS...\033[0m")
            sleep(1)
            
            # Codificación correcta para evitar fallas con espacios o caracteres raros
            query_encoded = urllib.parse.quote(zona_busqueda)
            url_api = f"https://nominatim.openstreetmap.org/search.php?q={query_encoded}&format=json"
            
            # Request estructurada con el User-Agent propio para evitar el Error 403
            req = urllib.request.Request(
                url_api,
                headers={'User-Agent': f'TRX-LILL-AdvancedLookup/2.0 (Contact: trx_lill@custom.osint)'}
            )
            
            with urllib.request.urlopen(req) as respuesta:
                datos = json.loads(respuesta.read().decode())
                
                if datos:
                    latitud = datos[0]["lat"]
                    longitud = datos[0]["lon"]
                    print(f"\033[1;33m[v]\033[0m LATITUD: \033[1;32m{latitud}\033[0m")
                    print(f"\033[1;33m[v]\033[0m LONGITUD: \033[1;32m{longitud}\033[0m")
                    print(f"\033[1;33m[v]\033[0m ENLACE DE MAPA: \033[1;36mhttps://www.google.com/maps/place/{latitud},{longitud}\033[0m")
                    
                    # Guardar una copia local en JSON
                    reporte_json = {"Numero": numero_internacional, "Latitud": latitud, "Longitud": longitud, "Pais": pais}
                    with open("trx_resultado.json", "w", encoding="utf-8") as f_json:
                        json.dump(reporte_json, f_json, indent=4, ensure_ascii=False)
                    print("\n\033[1;32m[+]\033[0m Datos guardados exitosamente en 'trx_resultado.json'")
                else:
                    print("\033[1;31m[-] No se localizaron coordenadas exactas en Nominatim para la región.\033[0m")
        else:
            print("\033[1;31m[-] No hay datos de región suficientes para calcular coordenadas geográficas.\033[0m")

    except Exception as error:
        print(f"\033[1;31m[-] ERROR DURANTE LA EJECUCIÓN: {error}\033[0m")

if __name__ == "__main__":
    buscar_numero()
