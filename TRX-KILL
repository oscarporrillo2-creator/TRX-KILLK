def menu_codigos_pais():
    print("\033[1;36m\n[!] ¿No sabes el código del país? Elígelo de la lista:\033[0m")
    contador = 1
    opciones = {}
    
    for continente, paises in PREFIJOS_PAISES.items():
        print(f"\n--- {continente} ---")
        for pais, codigo in paises.items():
            print(f" [\033[1;32m{contador}\033[0m] {pais} (+{codigo})")
            opciones[str(contador)] = codigo
            contador += 1
            
    print(f" [\033[1;31m0\033[0m] Introducir código manualmente")
    
    eleccion = input("\n\033[1;32m[?]\033[0m Selecciona una opción: ").strip()
    if eleccion in opciones:
        return opciones[eleccion]
    return ""

def guardar_reportes(datos_completos, num_limpio):
    # Crear la carpeta de salida automáticamente si no existe
    carpeta_salida = "Resultados_TRX"
    if not os.path.exists(carpeta_salida):
        os.makedirs(carpeta_salida)
        print(f"\033[1;32m[+]\033[0m Carpeta '{carpeta_salida}' generada de manera automática.")

    # Formatear nombre de archivo con ID limpio
    id_archivo = num_limpio.replace("+", "")
    ruta_txt = os.path.join(carpeta_salida, f"reporte_{id_archivo}.txt")
    ruta_json = os.path.join(carpeta_salida, f"reporte_{id_archivo}.json")

    # Guardar Reporte en TXT de lectura rápida
    with open(ruta_txt, "w", encoding="utf-8") as txt_file:
        txt_file.write(f"=== REPORTE OSINT POR TRX-LILL ===\n")
        txt_file.write(f"Fecha de consulta: {datos_completos['Fecha_Consulta']}\n")
        txt_file.write("-" * 40 + "\n")
        for clave, valor in datos_completos.items():
            if clave != "Zonas_Horarias":
                txt_file.write(f"{clave}: {valor}\n")
        txt_file.write("Zonas Horarias detectadas:\n")
        for tz in datos_completos["Zonas_Horarias"]:
            txt_file.write(f" - {tz}\n")

    # Guardar Reporte en JSON para estructuración limpia
    with open(ruta_json, "w", encoding="utf-8") as json_file:
        json.dump(datos_completos, json_file, indent=4, ensure_ascii=False)

    print(f"\n\033[1;32m[+]\033[0m Archivos de reporte almacenados exitosamente en:")
    print(f"    \033[1;36m-> {ruta_txt}\033[0m")
    print(f"    \033[1;36m-> {ruta_json}\033[0m")

def buscar_numero():
    mostrar_banner()
    entrada = input("\033[1;32m[?]\033[0m Introduce el número de teléfono: ").strip()
    
    # Limpieza absoluta del número usando Regex
    num_limpio = re.sub(r'[^\d+]', '', entrada)
    
    # Validar si el usuario incluyó un prefijo internacional válido
    if not num_limpio.startswith("+") and len(num_limpio) < 11:
        print("\033[1;33m[-] Advertencia: El número no parece incluir un código de país válido.\033[0m")
        codigo = menu_codigos_pais()
        if codigo:
            num_limpio = "+" + codigo + num_limpio
        else:
            manual = input("\033[1;32m[?]\033[0m Escribe el código de país manualmente (ej: 34): ").strip()
            num_limpio = "+" + manual.replace("+", "") + num_limpio
    elif not num_limpio.startswith("+"):
        num_limpio = "+" + num_limpio

    print(f"\033[1;34m\n[*] PROCESANDO ENTRADA LIMPIA: {num_limpio}...\033[0m")
    sleep(1.5)

    try:
        phone_obj = phonenumbers.parse(num_limpio, None)
        
        if not phonenumbers.is_valid_number(phone_obj):
            print("\033[1;31m[-] ATENCIÓN: El formato estructural no es válido según los estándares.\033[0m")
            if not phonenumbers.is_possible_number(phone_obj):
                print("\033[1;31m[-] ERROR FATAL: El rango de este número es numéricamente imposible.\033[0m")
                return
        else:
            print("\033[1;32m[I] ESTADO: Estructura telefónica válida verificada.\033[0m")

        # Extracción avanzada de información
        numero_e164 = phonenumbers.format_number(phone_obj, phonenumbers.PhoneNumberFormat.E164).replace("+", "")
        prefijo_pais = phonenumbers.format_number(phone_obj, phonenumbers.PhoneNumberFormat.INTERNATIONAL).split(" ")[0]
        codigo_region = phonenumbers.region_code_for_country_code(int(prefijo_pais.replace("+", "")))
        numero_local = phonenumbers.format_number(phone_obj, phonenumbers.PhoneNumberFormat.E164).replace(prefijo_pais.replace("+", ""), "")
        numero_internacional = phonenumbers.format_number(phone_obj, phonenumbers.PhoneNumberFormat.INTERNATIONAL)

        pais = geocoder.country_name_for_number(phone_obj, "es")
        localizacion = geocoder.description_for_number(phone_obj, "es")
        operador = carrier.name_for_number(phone_obj, "es")

        print(f"\033[1;33m[v]\033[0m NÚMERO INTERNACIONAL: {numero_internacional}")
        print(f"\033[1;33m[v]\033[0m NÚMERO LOCAL: {numero_local}")
        print(f"\033[1;33m[v]\033[0m PREFIJO DE PAÍS: {prefijo_pais}")
        print(f"\033[1;33m[v]\033[0m CÓDIGO DE PAÍS (ISO): {codigo_region}")
        print(f"\033[1;33m[v]\033[0m PAÍS DE ORIGEN: {pais}")
        print(f"\\033[1;33m[v]\033[0m ÁREA / PROVINCIA: {localizacion if localizacion else 'No especificada'}")
        print(f"\033[1;33m[v]\033[0m OPERADOR TELEFÓNICO / ISP: {operador if operador else 'Desconocido'}")

        listado_tz = []
        idx = 1
        for tz in timezone.time_zones_for_number(phone_obj):
            print(f"\033[1;33m[v]\033[0m ZONA HORARIA N°{idx}: {tz}")
            listado_tz.append(tz)
            idx += 1

        print("\033[1;32m\n[+] FORMATEANDO ESTRUCTURAS DE NÚMERO...\033[0m")
        fmt_rfc3966 = f"tel:{numero_internacional.replace(' ', '-')}"
        print(f"\033[1;33m[v]\033[0m FORMATO INTERNACIONAL E164: +{numero_e164}")
        print(f"\033[1;33m[v]\033[0m FORMATO RFC3966: {fmt_rfc3966}")

        # Diccionario base para almacenar localmente
        reporte_datos = {
            "Fecha_Consulta": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            "Numero_Internacional": numero_internacional,
            "Numero_Local": numero_local,
            "Prefijo_Pais": prefijo_pais,
            "Codigo_ISO": codigo_region,
            "Pais": pais,
            "Region_Provincia": localizacion if localizacion else "No especificada",
            "Operador": operador if operador else "Desconocido",
            "Format_E164": f"+{numero_e164}",
            "Format_RFC3966": fmt_rfc3966,
            "Zonas_Horarias": listado_tz,
            "Latitud": "No disponible",
            "Longitud": "No disponible",
            "Google_Maps": "No disponible"
        }

        # Geolocalización API Nominatim sin error 403
        zona_busqueda = localizacion if localizacion else pais
        if zona_busqueda:
            print("\033[1;32m\n[+] CONSULTANDO COORDENADAS GEOGRÁFICAS EXTERNAS...\033[0m")
            query_encoded = urllib.parse.quote(zona_busqueda)
            url_api = f"https://nominatim.openstreetmap.org/search.php?q={query_encoded}&format=json"
            
            req = urllib.request.Request(
                url_api,
                headers={'User-Agent': 'TRX-LILL-AdvancedLookup/2.0 (Contact: trx_lill@custom.osint)'}
            )
            
            try:
                with urllib.request.urlopen(req) as respuesta:
                    datos = json.loads(respuesta.read().decode())
                    if datos:
                        latitud = datos[0]["lat"]
                        longitud = datos[0]["lon"]
                        link_maps = f"https://www.google.com/maps/place/{latitud},{longitud}"
                        
                        print(f"\033[1;33m[v]\033[0m LATITUD: \033[1;32m{latitud}\033[0m")
                        print(f"\033[1;33m[v]\033[0m LONGITUD: \033[1;32m{longitud}\033[0m")
                        print(f"\033[1;33m[v]\033[0m ENLACE DE MAPA: \033[1;36m{link_maps}\033[0m")
                        
                        reporte_datos["Latitud"] = latitud
                        reporte_datos["Longitud"] = longitud
                        reporte_datos["Google_Maps"] = link_maps
                    else:
                        print("\033[1;31m[-] No se devolvieron coordenadas exactas para la zona de registro.\033[0m")
            except Exception as e:
                print(f"\033[1;31m[-] Error al consultar la API geográfica: {e}\033[0m")

        # Guardar en la nueva carpeta automatizada
        guardar_reportes(reporte_datos, num_limpio)

    except Exception as error:
        print(f"\033[1;31m[-] ERROR DURANTE LA EJECUCIÓN: {error}\033[0m")

if __name__ == "__main__":
    buscar_numero()
