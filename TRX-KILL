def main():
    while True:
        banner()
        print(" [1] OSINT NГҡMERO REAL   | [2] RASTREO REAL (LINK)")
        print(" [3] INFO IP REAL        | [4] ESCANEO PUERTOS")
        print(" [8] LEER RESULTADOS     | [9] SALIR")
        opc = input("\nTRX-ROOT > ")
        
        if opc == "1":
            try:
                num = input("NГәmero (Ej: +5411...): ")
                p = phonenumbers.parse(num)
                print(f"[+] PaГӯs: {geocoder.country_name_for_number(p, 'es')}")
                print(f"[+] Operador: {carrier.name_for_number(p, 'es')}")
                print(f"[+] Estado: {'LГӯnea Activa' if is_valid_number(p) else 'InvГЎlida'}")
            except Exception as e: print(f"[-] Error: {e}")
            input("\n[Enter]...")
        elif opc == "2":
            threading.Thread(target=lambda: app.run(host='0.0.0.0', port=PUERTO), daemon=True).start()
            proc = subprocess.Popen(['ssh', '-R', '80:localhost:'+str(PUERTO), 'serveo.net'], stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
            for line in proc.stderr:
                if "https://" in line: print(f"\nLINK: {line.strip()}\n"); break
            input("Presiona Enter para cerrar..."); os.system('pkill -f ssh')
        elif opc == "3":
            ip = input("IP a analizar: ")
            data = requests.get(f"http://ip-api.com/json/{ip}").json()
            print(f"[+] UbicaciГіn: {data.get('city')}, {data.get('country')}")
            print(f"[+] ISP: {data.get('isp')}")
            input("\n[Enter]...")
        elif opc == "4":
            target = input("Target IP: ")
            os.system(f"nmap -F {target}")
            input("\n[Enter]...")
        elif opc == "8":
            if os.path.exists("resultados.txt"): os.system("cat resultados.txt")
            else: print("Sin registros.")
            input("\n[Enter]...")
        elif opc == "9": sys.exit()

if __name__ == "__main__":
    main()
