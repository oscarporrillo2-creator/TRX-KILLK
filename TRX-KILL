def analizar_infraestructura_hlr():
    entrada = input("\033[1;32m[?]\033[0m Ingrese el número de teléfono objetivo: ").strip()
    num_limpio = re.sub(r'[^\d]', '', entrada)

    if len(num_limpio) < 8:
        print("\033[1;31m[-] Número demasiado corto para análisis estructural.\033[0m")
        sleep(1.5)
        return

    print(f"\033[1;34m\n[*] INTERCEPTANDO PREFIJOS DE ENRUTAMIENTO: +{num_limpio}...\033[0m")
    sleep(1.5)

    # Identificación técnica por diccionario de red
