# SECCIÓN 1: ANÁLISIS DE TELEFONÍA (MÓVIL)
# ========================================================
class Phony:

    @staticmethod
    def Number(num, report, code="", Mode="", Type="", username=""):
        phoneList = []
        Clear.Screen.Clear()
        mostrar_banner_trx()
        
        print(Font.Color.GREEN + "[+]" + Font.Color.WHITE + " TRX-KILL ENGINE: ANALIZANDO IDENTIFICADOR: +{}".format(num))
        sleep(1)
        FormattedPhoneNumber = "+" + num
        
        try:
            Phone = phonenumbers.parse(FormattedPhoneNumber, None)
        except Exception:
            print(Font.Color.RED + "\n[!]" + Font.Color.WHITE + " Estructura de numeración inválida o no reconocida.")
            return phoneList
        else:
            if not phonenumbers.is_valid_number(Phone):
                reality = "Número no asignado o inválido según la UIT."
                print(Font.Color.RED + "\n[!]" + Font.Color.WHITE + reality)
            else:
                reality = "Estructura de Línea Válida / Activa"
                print(Font.Color.BLUE + "\n[I]" + Font.Color.WHITE + reality)

            number = phonenumbers.format_number(Phone, phonenumbers.PhoneNumberFormat.E164).replace("+", "")
            numberCode = phonenumbers.format_number(Phone, phonenumbers.PhoneNumberFormat.INTERNATIONAL).split(" ")[0]
            numberNation = phonenumbers.region_code_for_country_code(int(numberCode))

            localNumber = phonenumbers.format_number(Phone, phonenumbers.PhoneNumberFormat.E164).replace(numberCode, "")
            international = phonenumbers.format_number(Phone, phonenumbers.PhoneNumberFormat.INTERNATIONAL)

            nation = geocoder.country_name_for_number(Phone, "es")
            carrierName = carrier.name_for_number(Phone, "es")

            print(Font.Color.YELLOW + "\n[v]" + Font.Color.WHITE + " NÚMERO INTERNACIONAL: {}".format(international))
            print(Font.Color.YELLOW + "[v]" + Font.Color.WHITE + " NÚMERO LOCAL: {}".format(localNumber))
            print(Font.Color.YELLOW + "[v]" + Font.Color.WHITE + " PREFIJO DE PAÍS: {}".format(numberCode))
            print(Font.Color.YELLOW + "[v]" + Font.Color.WHITE + " CÓDIGO DE REGIÓN: {}".format(numberNation))
            print(Font.Color.YELLOW + "[v]" + Font.Color.WHITE + " PAÍS DETECTADO: {}".format(nation))
            print(Font.Color.YELLOW + "[v]" + Font.Color.WHITE + " OPERADORA / CARRIER: {}".format(carrierName if carrierName else "No disponible"))
            
            i = 1
            for timezoneResult in timezone.time_zones_for_number(Phone):
                print(Font.Color.YELLOW + "[v]" + Font.Color.WHITE + " ZONA HORARIA N°{}: {}".format(i, timezoneResult))
                i = i + 1
            sleep(1)

            try:
                with open(report, "a", encoding="utf-8") as f:
                    f.write("=== TRX-KILL REPORT ===\n")
                    f.write(f"INTERNATIONAL NUMBER: {international}\n")
                    f.write(f"LOCAL NUMBER: {localNumber}\n")
                    f.write(f"COUNTRY PREFIX: {numberCode}\n")
                    f.write(f"COUNTRY CODE: {numberNation}\n")
                    f.write(f"COUNTRY: {str(nation)}\n")
                    f.write(f"CARRIER/ISP: {str(carrierName)}\n")
                    f.write("=======================\n")
            except Exception:
                pass

            formatted2 = str(international).replace(numberCode, "").replace(" ", "-")
            formatted3 = formatted2.replace("-", "", 1)
            formatted4 = str(international).replace(numberCode, "0").replace(" ", "")
            formatted1 = "({}{}){}".format("%2B", numberCode, str(formatted2).replace("-", "", 1))
            formatted5 = formatted4.replace("0", "", 1)
            
            phoneList.extend([formatted1, formatted2, formatted4, formatted5])
            
            print(Font.Color.GREEN + "\n[+]" + Font.Color.WHITE + " GENERANDO PAYLOADS DE BÚSQUEDA...")
            sleep(1)
            print(Font.Color.YELLOW + "[v]" + Font.Color.WHITE + " FORMATO RFC3966: " + formatted1.replace("%2B", ""))
            print(Font.Color.YELLOW + "[v]" + Font.Color.WHITE + " FORMATO STANDARDIZED: " + formatted3)
            
            return phoneList


