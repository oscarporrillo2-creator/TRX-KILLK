    print(f"  -> CÓDIGO INTERNACIONAL MCC: {info_red['mcc']}")
    print(f"  -> INFRAESTRUCTURA TÉCNICA: {tipo_asignacion}")
    print("\033[1;31m=====================================================\033[0m")
