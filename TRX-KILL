def obtener_coordenadas_pais(codigo_region):
    coordenadas = {
        "AR": "-34.6037,-58.3816", "MX": "19.4326,-99.1332", "CO": "4.7110,-74.0721",
        "ES": "40.4167,-3.7037",  "PE": "-12.0464,-77.0428", "CL": "-33.4489,-70.6693",
        "VE": "10.4806,-66.9036", "EC": "-0.1807,-78.4678", "BR": "-15.7938,-47.8828",
        "US": "37.0902,-95.7129", "UY": "-34.9011,-56.1645", "BO": "-16.2902,-63.5887"
    }
    return coordenadas.get(codigo_region.upper(), "0.0000,0.0000")


# ========================================================
# OPCIÓN 1: BÚSQUEDA DE NÚMERO
# ========================================================
def modulo_lookup_numero():
    Clear.Screen.Clear()
    mostrar_banner_trx()
    num = input("\033[1;32m[+] Ingresa el número (ej: 54911xxxxxxxx sin +): \033[0m")
    
    try:
        Phone = phonenumbers.parse("+" + num, None)
    except Exception:
        print("\033[1;31m\n[!] Formato de número inválido.\033[0m")
        return

    if not phonenumbers.is_valid_number(Phone):
        print("\033[1;31m\n[!] El número ingresado no es válido estructuralmente.\033[0m")
        return

    pais = geocoder.country_name_for_number(Phone, "es")
    operadora = carrier.name_for_number(Phone, "es")
    region_code = phonenumbers.region_code_for_country_code(Phone.country_code)
    coordenadas_ip = obtener_coordenadas_pais(region_code)
    google_maps_link = f"https://www.google.com/maps?q={coordenadas_ip}"
    
    print("\n\033[1;32m[+] DATOS EXTRAÍDOS DEL NÚMERO:\033[0m")
    print(f"\033[1;36mMÓVIL:\033[0m +{num}")
    print(f"\033[1;36mPAÍS:\033[0m {pais} ({region_code})")
    print(f"\033[1;36mOPERADORA:\033[0m {operadora if operadora else 'No detectada'}")
    print(f"\033[1;36mUBICACIÓN GENERAL PAÍS:\033[0m {coordenadas_ip}")
    print(f"\033[1;36mGOOGLE MAP PAÍS:\033[0m {google_maps_link}")


