    print(f"{BOLD}   ╔════════════════════════════════════╗")
    print(f"   ║        TRX-KILL v20.0 ELITE        ║")
    print(f"   ║      DESARROLLADO POR: TRX-LILL    ║")
    print(f"   ║          AÑO: 2026                 ║")
