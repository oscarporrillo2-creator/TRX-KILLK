# --- OPCIÓN 1: CONSULTA EXTENDIDA ---
def consulta_extendida():
    os.system('clear')
    num = input("[+] Ingresa el número (+54...): ")
    try:
        p = phonenumbers.parse(num, None)
        print(f"\n[!] VERIFICANDO NÚMERO...")
        sleep(1.5)
        
        print(f"\nMÓVIL: {num}")
        print(f"PAÍS: {geocoder.country_name_for_number(p, 'es')}")
        print(f"MAPA: Coordenadas estimadas para {geocoder.country_name_for_number(p, 'es')}")
        print(f"GOOGLE MAP LINK: https://www.google.com/maps/search/{geocoder.country_name_for_number(p, 'es')}")
