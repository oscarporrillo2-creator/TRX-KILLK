class TrxKillScanner:

    @staticmethod
    def Scraping(report, username, http_proxy, InstagramParams, PostLocations, PostGpsCoordinates, TwitterParams):
        base_dir = "GUI/Reports/Usernames/{}".format(username)
        if not os.path.exists(base_dir):
            os.makedirs(base_dir, exist_ok=True)
        
        pic_dir = os.path.join(base_dir, "Profile_pics")
        if not os.path.exists(pic_dir):
            os.makedirs(pic_dir, exist_ok=True)

        for platform in ["Instagram", "Twitter", "TikTok", "Github", "GitLab", "Ngl", "Tellonym", "Gravatar"]:
            try:
                if platform == "Instagram":
                    Scraper.info.Instagram(report, username, http_proxy, InstagramParams, PostLocations, PostGpsCoordinates, "Usernames", username)
                elif platform == "Twitter":
                    Scraper.info.Twitter(report, username, http_proxy, TwitterParams, "Usernames", username)
                elif platform == "TikTok":
                    Scraper.info.TikTok(report, username, http_proxy, "Usernames", username)
                elif platform == "Github":
                    Scraper.info.Github(report, username, http_proxy, "Usernames", username)
                elif platform == "GitLab":
                    Scraper.info.GitLab(report, username, http_proxy, "Usernames", username)
            except Exception:
                print(Font.Color.RED + "[!]" + Font.Color.WHITE + f" Error al procesar plataforma: {platform}")

