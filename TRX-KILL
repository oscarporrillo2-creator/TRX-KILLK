def obtener_bateria():
    porcentaje = "Desconocido"
    estado = "Desconocido"
    rutas_capacidad = ['/sys/class/power_supply/battery/capacity', '/sys/class/power_supply/usb/capacity']
    rutas_estado = ['/sys/class/power_supply/battery/status', '/sys/class/power_supply/usb/status']
    
    for ruta in rutas_capacidad:
        if os.path.exists(ruta):
            with open(ruta, 'r') as f: porcentaje = f.read().strip() + "%"
            break
    for ruta in rutas_estado:
        if os.path.exists(ruta):
            with open(ruta, 'r') as f:
                est_raw = f.read().strip().lower()
                if est_raw == "charging": estado = "Cargando ⚡"
                elif est_raw == "discharging": estado = "Descargándose 🔋"
                elif est_raw == "full": estado = "Completa ✅"
                else: estado = est_raw.capitalize()
            break
    return porcentaje, estado

