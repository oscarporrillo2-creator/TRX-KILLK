def guardar_reporte(datos, identificador, tipo):
    carpeta_salida = "Resultados_TRX"
    if not os.path.exists(carpeta_salida):
        os.makedirs(carpeta_salida)
    
    nombre_limpio = identificador.replace("+", "").replace(".", "_")
    ruta_txt = os.path.join(carpeta_salida, f"reporte_{tipo}_{nombre_limpio}.txt")
    
    with open(ruta_txt, "w", encoding="utf-8") as f:
        f.write(f"=== REPORTE OSINT TRX-KILL ({tipo.upper()}) ===\n")
        f.write(f"Fecha: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")
        for k, v in datos.items():
            f.write(f"{k}: {v}\n")
            
    print(f"\n\033[1;32m[+]\033[0m Reporte guardado localmente en:\n    \033[1;36m-> {ruta_txt}\033[0m")

def menu_codigos_pais():
    print("\033[1;36m\n[!] ¿No sabes el código del país? Elígelo de la lista:\033[0m")
    contador = 1
    opciones = {}
    for continente, countries in PREFIJOS_PAISES.items():
        print(f"\n--- {continente} ---")
        for pais, codigo in countries.items():
            print(f" [\033[1;32m{contador}\033[0m] {pais} (+{codigo})")
            opciones[str(contador)] = codigo
            contador += 1
    eleccion = input("\n\033[1;32m[?]\033[0m Selecciona una opción: ").strip()
    return opciones.get(eleccion, "")

def buscar_telefono():
    entrada = input("\033[1;32m[?]\033[0m Introduce el número de teléfono: ").strip()
    num_limpio = re.sub(r'[^\d]', '', entrada)

    if len(num_limpio) < 10:
        codigo = menu_codigos_pais()
        if codigo:
            num_limpio = codigo + num_limpio
        else:
            num_limpio = input("\033[1;32m[?]\033[0m Introduce el prefijo manualmente (ej: 54): ").strip() + num_limpio

    print(f"\033[1;34m\n[*] ANALIZANDO TELÉFONO: +{num_limpio}...\033[0m")
    sleep(1)

    pais_final = "Desconocido"
    todos_los_prefijos = []
    for cont, paises in PREFIJOS_PAISES.items():
        for p, c in paises.items():
            todos_los_prefijos.append((p, c))
    todos_los_prefijos.sort(key=lambda x: len(x[1]), reverse=True)
    
    for p, c in todos_los_prefijos:
        if num_limpio.startswith(c):
            pais_final = p
            break

    print(f"\033[1;33m[v]\033[0m PAÍS DETECTADO: {pais_final}")
    
    if pais_final != "Desconocido":
        try:
            query_encoded = urllib.parse.quote(pais_final)
            url_api = f"https://nominatim.openstreetmap.org/search.php?q={query_encoded}&format=json"
            req_geo = urllib.request.Request(url_api, headers={'User-Agent': 'TRX-LILL/3.0'})
            with urllib.request.urlopen(req_geo) as resp:
                datos_geo = json.loads(resp.read().decode())
                if datos_geo:
                    lat = datos_geo[0]["lat"]
                    lon = datos_geo[0]["lon"]
                    link_maps = f"https://www.google.com/maps/place/{lat},{lon}"
                    print(f"\033[1;33m[v]\033[0m MAPS: \033[1;36m{link_maps}\033[0m")
                    
                    rep = {"Numero": num_limpio, "Pais": pais_final, "Latitud": lat, "Longitud": lon, "Enlace": link_maps}
                    guardar_reporte(rep, num_limpio, "telefono")
        except Exception as e:
            print(f"\033[1;31m[-] Error al obtener coordenadas: {e}\033[0m")

def analizar_datos_ip(ip_address):
    try:
        url = f"http://ip-api.com/json/{ip_address}"
        req = urllib.request.Request(url, headers={'User-Agent': 'TRX-LILL/3.0'})
        with urllib.request.urlopen(req) as resp:
            data = json.loads(resp.read().decode())
            
            if data.get("status") == "success":
                print(f"\033[1;33m[v]\033[0m PAÍS IP: {data.get('country')} ({data.get('countryCode')})")
                print(f"\033[1;33m[v]\033[0m REGIÓN/ESTADO: {data.get('regionName')}")
                print(f"\033[1;33m[v]\033[0m CIUDAD: {data.get('city')}")
                print(f"\033[1;33m[v]\033[0m PROVEEDOR (ISP): {data.get('isp')}")
                print(f"\033[1;33m[v]\033[0m LATITUD: {data.get('lat')}")
                print(f"\033[1;33m[v]\033[0m LONGITUD: {data.get('lon')}")
                
                link_maps = f"https://www.google.com/maps/place/{data.get('lat')},{data.get('lon')}"
                print(f"\033[1;33m[v]\033[0m GOOGLE MAPS: \033[1;36m{link_maps}\033[0m")
                
                rep = {
                    "IP": ip_address, "Pais": data.get('country'), "Region": data.get('regionName'),
                    "Ciudad": data.get('city'), "ISP": data.get('isp'), "Latitud": data.get('lat'),
                    "Longitud": data.get('lon'), "Maps": link_maps
                }
                guardar_reporte(rep, ip_address, "ip")
            else:
                print("\033[1;31m[-] Rango de IP no localizable.\033[0m")
    except Exception as e:
        print(f"\033[1;31m[-] Error en el módulo de IP: {e}\033[0m")

def buscar_ip():
    ip = input("\033[1;32m[?]\033[0m Introduce la dirección IP a rastrear: ").strip()
    print(f"\033[1;34m\n[*] RASTREANDO IP: {ip}...\033[0m")
    sleep(1)
    analizar_datos_ip(ip)

def combo_telefono_e_ip():
    # 1. Solicitar el número de teléfono
    entrada = input("\033[1;32m[?]\033[0m Ingresa el número de teléfono a analizar: ").strip()
    num_limpio = re.sub(r'[^\d]', '', entrada)

    if len(num_limpio) < 10:
        codigo = menu_codigos_pais()
        if codigo:
            num_limpio = codigo + num_limpio
        else:
            num_limpio = input("\033[1;32m[?]\033[0m Prefijo manual (ej: 54): ").strip() + num_limpio

    print(f"\033[1;34m\n[*] PASO 1: EXTRAYENDO DATOS DEL TELÉFONO: +{num_limpio}...\033[0m")
    sleep(1.5)

    # Buscar el país del número
    pais_final = "Desconocido"
    todos_los_prefijos = []
    for cont, paises in PREFIJOS_PAISES.items():
        for p, c in paises.items():
            todos_los_prefijos.append((p, c))
    todos_los_prefijos.sort(key=lambda x: len(x[1]), reverse=True)
    
    for p, c in todos_los_prefijos:
        if num_limpio.startswith(c):
            pais_final = p
            break

    print(f"\033[1;32m[+]\033[0m Red de Origen del número: {pais_final}")
    
    if pais_final != "Desconocido":
        try:
            query_encoded = urllib.parse.quote(pais_final)
            url_api = f"https://nominatim.openstreetmap.org/search.php?q={query_encoded}&format=json"
            req_geo = urllib.request.Request(url_api, headers={'User-Agent': 'TRX-LILL/3.0'})
            with urllib.request.urlopen(req_geo) as resp:
                datos_geo = json.loads(resp.read().decode())
                if datos_geo:
                    lat = datos_geo[0]["lat"]
                    lon = datos_geo[0]["lon"]
                    link_maps = f"https://www.google.com/maps/place/{lat},{lon}"
                    print(f"\033[1;33m[v]\033[0m Estado de Línea: \033[1;32mASIGNADA / MÓVIL\033[0m")
                    print(f"\033[1;33m[v]\033[0m Mapa Base del Teléfono: \033[1;36m{link_maps}\033[0m")
        except Exception:
            print("\033[1;31m[-] Saltando coordenadas base del teléfono...\033[0m")

    # 2. Extraer automáticamente la IP de la conexión y analizarla de inmediato
    print("\033[1;34m\n[*] PASO 2: RASTREANDO LA IP DE CONEXIÓN DEL TERMINAL...\033[0m")
    sleep(1.5)
    try:
        url_mi_ip = "https://api.ipify.org?format=json"
        req_mi_ip = urllib.request.Request(url_mi_ip, headers={'User-Agent': 'TRX-LILL/3.0'})
        with urllib.request.urlopen(req_mi_ip) as resp_ip:
            datos_ip = json.loads(resp_ip.read().decode())
            ip_publica = datos_ip.get("ip")
            
            if ip_publica:
                print(f"\033[1;32m[+]\033[0m IP del teléfono extraída: \033[1;36m{ip_publica}\033[0m")
                print("\033[1;34m[*] Desglosando geolocalización de red de la IP...\033[0m\n")
                sleep(1)
                analizar_datos_ip(ip_publica)
            else:
                print("\033[1;31m[-] No se pudo capturar la IP de la antena móvil.\033[0m")
    except Exception as e:
        print(f"\033[1;31m[-] Error al obtener IP de red: {e}\033[0m")

