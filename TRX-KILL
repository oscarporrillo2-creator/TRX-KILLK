            numberCode = phonenumbers.format_number(Phone, phonenumbers.PhoneNumberFormat.INTERNATIONAL).split(" ")[0]
            numberNation = phonenumbers.region_code_for_country_code(int(numberCode))

            localNumber = phonenumbers.format_number(Phone, phonenumbers.PhoneNumberFormat.E164).replace(numberCode, "")
            international = phonenumbers.format_number(Phone, phonenumbers.PhoneNumberFormat.INTERNATIONAL)

            nation = geocoder.country_name_for_number(Phone, "es")
            location = geocoder.description_for_number(Phone, "es")
            carrierName = carrier.name_for_number(Phone, "es")

            # Despliegue de Metadatos de Red Reales
            print(Font.Color.YELLOW + "\n[v]" + Font.Color.WHITE + " NÚMERO INTERNACIONAL: {}".format(international))
            print(Font.Color.YELLOW + "[v]" + Font.Color.WHITE + " NÚMERO LOCAL: {}".format(localNumber))
            print(Font.Color.YELLOW + "[v]" + Font.Color.WHITE + " PREFIJO DE PAÍS: {}".format(numberCode))
            print(Font.Color.YELLOW + "[v]" + Font.Color.WHITE + " CÓDIGO DE REGIÓN: {}".format(numberNation))
            print(Font.Color.YELLOW + "[v]" + Font.Color.WHITE + " PAÍS DETECTADO: {}".format(nation))
            print(Font.Color.YELLOW + "[v]" + Font.Color.WHITE + " OPERADORA / CARRIER: {}".format(carrierName if carrierName else "No disponible"))
            
            i = 1
            for timezoneResult in timezone.time_zones_for_number(Phone):
                print(Font.Color.YELLOW + "[v]" + Font.Color.WHITE + " ZONA HORARIA N°{}: {}".format(i, timezoneResult))
                i = i + 1
            sleep(1)

            # Escritura limpia del reporte local
