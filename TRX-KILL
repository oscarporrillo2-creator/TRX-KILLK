        try:
            with open(nomefile, 'r', encoding='utf-8') as f:
                data = json.load(f)
        except Exception:
            print(Font.Color.RED + "[!]" + Font.Color.WHITE + " Error al cargar base de datos de objetivos.")
            return

        print(Font.Color.GREEN + "\n[+]" + Font.Color.WHITE + " PASARELA DE PROXY ACTIVA: {}".format(http_proxy2))
        
        for sites in data:
            for data1 in sites:
                site1 = sites[data1]["user"].replace("{}", username)
                site2 = sites[data1]["user2"].replace("{}", username)
                name = sites[data1]["name"]
                error = sites[data1]["Error"]
