    # Enlaces de mapeo de red y pivots
    link_maps = f"https://www.google.com/maps?q={info_red['lat']},{info_red['lon']}" if info_red['mcc'] != "Desconocido" else "N/A"
    link_wa = f"https://wa.me/{num_limpio}"
    link_tg = f"tg://resolve?phone={num_limpio}"

    print("\n\033[1;31m=====================================================\033[0m")
    print(f"\033[1;32m [I] METADATOS DE TELECOMUNICACIONES:\033[0m")
    print(f"  -> IDENTIFICADOR NACIONAL:  +{num_limpio}")
