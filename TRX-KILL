# --- MÓDULO 1: CONSULTA RÁPIDA ---
def consulta_rapida():
    Clear.Screen()
    mostrar_banner_trx()
    num = input("\033[1;32m[+] Ingresa número (ej: 54911xxxxxxxx): \033[0m")
    try:
        p = phonenumbers.parse("+" + num, None)
        print(f"\n\033[1;36m[✓] País: {geocoder.country_name_for_number(p, 'es')}\033[0m")
    except: print("\033[1;31m[!] Error.\033[0m")

# --- MÓDULO 2: INFORMATION-NÚMERO DETALLADO ---
def modulo_info_numero_avanzado():
    Clear.Screen()
    mostrar_banner_trx()
    print("\033[1;34m[+] ANÁLISIS OSINT: NÚMERO TELEFÓNICO DETALLADO\033[0m\n")
    num = input("\033[1;32m[+] Ingresa número: \033[0m")
    try:
        p = phonenumbers.parse("+" + num, None)
        if phonenumbers.is_valid_number(p):
            print(f"\n\033[1;36mPaís:\033[0m {geocoder.country_name_for_number(p, 'es')}")
            print(f"\033[1;36mZona horaria:\033[0m {', '.join(timezone.time_zones_for_number(p))}")
            print(f"\033[1;36mOperadora:\033[0m {carrier.name_for_number(p, 'es')}")
            print(f"\033[1;36mTipo de línea:\033[0m {'Móvil' if phonenumbers.number_type(p) == 1 else 'Fijo/Otro'}")
            print(f"\033[1;36mInternacional:\033[0m +{p.country_code}")
        else: print("\033[1;31m[!] Número inválido.\033[0m")
    except Exception as e: print(f"Error: {e}")

