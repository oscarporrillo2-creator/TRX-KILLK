# ========================================================
# OPCIÓN 3: PORR-SCANNER
# ========================================================
def modulo_porr_scanner():
    Clear.Screen.Clear()
    mostrar_banner_trx()
    target = input("\033[1;32m[+] IP a escanear: \033[0m")
    for port in [21, 22, 80, 443]:
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(0.5)
        if s.connect_ex((target, port)) == 0:
            print(f"\033[1;32m[*] Puerto {port}: ABIERTO\033[0m")
        else:
            print(f"\033[1;31m[-] Puerto {port}: CERRADO\033[0m")


